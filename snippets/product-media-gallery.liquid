{%- doc -%}
  Product media gallery in editorial 2-by-2 format: small sticky thumbnails on the left, large media grid, sticky product info on the right.
{%- enddoc -%}

{%- liquid
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign media_count = product.media.size
  if hide_variants and media_count > 1
    assign media_count = media_count | minus: variant_images.size | plus: 1
  endif

  assign product_variant = product.selected_or_first_available_variant
  assign featured_media = product_variant.featured_media | default: product.featured_media

  assign product_subtitle = product_variant.title
  if product_subtitle == blank or product_subtitle == 'Default Title'
    assign product_subtitle = product.title | replace: 'Sac Ève ', '' | replace: 'SAC ÈVE ', '' | replace: 'Sac Eve ', '' | replace: 'SAC EVE ', ''
  endif
  assign product_subtitle = product_subtitle | replace: 'KakiOr', 'Kaki Or' | replace: 'NoirOr', 'Noir Or' | replace: 'KakiArgent', 'Kaki Argent' | replace: 'NoirArgent', 'Noir Argent'

  assign linked_count = 1
  assign linked_list = product.metafields.custom.linked_colors.value
  if linked_list == blank
    assign linked_list = product.metafields.custom.custom_linked_colors.value
  endif
  if linked_list == blank
    assign linked_list = product.metafields.custom.couleurs_liees.value
  endif
  if linked_list != blank
    assign linked_count = linked_list.size | plus: 1
  endif
-%}

