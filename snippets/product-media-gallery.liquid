  @media screen and (max-width: 1023px) {
    #ProductGallery-{{ section_id }}-{{ product_id }} .azp-thumbs-wrap { display: none !important; }
    #ProductGallery-{{ section_id }}-{{ product_id }} .azp-media-grid { display: flex !important; overflow-x: auto !important; scroll-snap-type: x mandatory !important; gap: 0 !important; scrollbar-width: none !important; }
    #ProductGallery-{{ section_id }}-{{ product_id }} .azp-media-grid::-webkit-scrollbar { display: none !important; }
    #ProductGallery-{{ section_id }}-{{ product_id }} .azp-media-tile { flex: 0 0 100% !important; width: 100% !important; aspect-ratio: 1 / 1 !important; position: relative !important; overflow: hidden !important; background: #f4f4f2 !important; scroll-snap-align: start !important; }
    #ProductGallery-{{ section_id }}-{{ product_id }} .azp-media-tile img,
    #ProductGallery-{{ section_id }}-{{ product_id }} .azp-media-tile video { position: absolute !important; inset: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; display: block !important; }
  }
</style>

<media-gallery id="ProductGallery-{{ section_id }}-{{ product_id }}" class="product__gallery block w-full relative{% if media_count == 1 %} with-only1{% endif %}" form="{{ product_form_id }}" aria-label="{{ 'products.media.gallery_viewer' | t | escape }}" role="region" data-animate="fade-up" data-immediate>
  {%- if media_count > 1 -%}
    <div class="azp-thumbs-wrap" aria-hidden="false">
      <div class="azp-thumbs-list" aria-controls="AzpMediaGrid-{{ section_id }}-{{ product_id }}">
        {%- if featured_media != null -%}
          {%- assign thumb_alt = featured_media.alt | default: product.title | escape -%}
          <button type="button" class="azp-thumb" data-media-id="{{ featured_media.id }}" aria-label="Image 1" aria-current="true">{{- featured_media.preview_image | image_url: width: 300 | image_tag: loading: 'lazy', sizes: '66px', widths: '132,198,300', alt: thumb_alt -}}</button>
        {%- endif -%}
        {%- for media in product.media -%}
          {%- if media.id != featured_media.id -%}
            {%- assign thumb_alt = media.alt | default: product.title | escape -%}
            <button type="button" class="azp-thumb" data-media-id="{{ media.id }}" aria-label="Image {{ forloop.index | plus: 1 }}" aria-current="false">{{- media.preview_image | image_url: width: 300 | image_tag: loading: 'lazy', sizes: '66px', widths: '132,198,300', alt: thumb_alt -}}</button>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <button type="button" class="azp-thumbs-arrow" aria-label="{{ 'general.pagination.next' | t | escape }}" data-product-thumbs-next><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg></button>
    </div>
  {%- endif -%}

  <div id="AzpMediaGrid-{{ section_id }}-{{ product_id }}" class="azp-media-grid">
    {%- if featured_media != null -%}
      {%- assign media_alt = featured_media.alt | default: product.title | escape -%}
      <div class="azp-media-tile" data-media-id="{{ featured_media.id }}">{{- featured_media.preview_image | image_url: width: 1440 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '(min-width: 1024px) 26vw, 100vw', widths: '720,960,1200,1440,1800', alt: media_alt -}}</div>
    {%- endif -%}
    {%- for media in product.media -%}
      {%- if media.id != featured_media.id -%}
        {%- assign media_alt = media.alt | default: product.title | escape -%}
        <div class="azp-media-tile" data-media-id="{{ media.id }}">{{- media.preview_image | image_url: width: 1440 | image_tag: loading: 'lazy', sizes: '(min-width: 1024px) 26vw, 100vw', widths: '720,960,1200,1440,1800', alt: media_alt -}}</div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if first_3d_model -%}<button class="button icon-with-text w-full" is="hover-button" aria-label="{{ 'products.product.xr_button_label' | t }}" data-shopify-xr data-shopify-model3d-id="{{ first_3d_model.id }}" data-shopify-model3d-default-id="{{ first_3d_model.id }}" data-shopify-title="{{ product.title | escape }}" data-shopify-xr-hidden><span class="btn-fill" data-fill></span><span class="btn-text">{%- render 'icon', icon: '3d-model' -%}{{ 'products.product.xr_button' | t }}</span></button>{%- endif -%}
</media-gallery>

<script>
  (() => {
    const gallery = document.getElementById('ProductGallery-{{ section_id }}-{{ product_id }}');
    if (!gallery || gallery.dataset.thumbsEnhanced === 'true') return;
    gallery.dataset.thumbsEnhanced = 'true';
    const section = document.getElementById('shopify-section-{{ section_id }}');
    const thumbsList = gallery.querySelector('.azp-thumbs-list');
    const mediaItems = Array.from(gallery.querySelectorAll('.azp-media-tile[data-media-id]'));
    const normalizeTitleSpacing = () => {
      const title = section?.querySelector('.product__title .heading');
      if (!title || title.dataset.spacingFixed === 'true') return;
      title.dataset.spacingFixed = 'true';
      title.childNodes.forEach((node) => {
        if (node.nodeType !== Node.TEXT_NODE) return;
        let text = node.textContent || '';
        text = text.replace(/SACÈVE/g, 'SAC ÈVE').replace(/SAC EVE/g, 'SAC EVE');
        text = text.replace(/KAKIOR/g, 'KAKI OR').replace(/NOIROR/g, 'NOIR OR').replace(/KAKIARGENT/g, 'KAKI ARGENT').replace(/NOIRARGENT/g, 'NOIR ARGENT');
        node.textContent = text;
      });
    };
    const setActiveThumb = (mediaId) => { gallery.querySelectorAll('.azp-thumb').forEach((thumb) => { thumb.setAttribute('aria-current', thumb.dataset.mediaId === mediaId ? 'true' : 'false'); }); };
    gallery.addEventListener('click', (event) => {
      const thumb = event.target.closest('.azp-thumb');
      if (!thumb || !gallery.contains(thumb)) return;
      const mediaId = thumb.dataset.mediaId;
      const media = mediaId ? gallery.querySelector(`.azp-media-tile[data-media-id="${mediaId}"]`) : null;
      if (!media) return;
      event.preventDefault(); event.stopPropagation(); setActiveThumb(mediaId); media.scrollIntoView({ behavior: 'smooth', block: 'start', inline: 'nearest' });
    }, true);
    if ('IntersectionObserver' in window && mediaItems.length) {
      const observer = new IntersectionObserver((entries) => { entries.forEach((entry) => { if (entry.isIntersecting && entry.intersectionRatio >= 0.35) setActiveThumb(entry.target.dataset.mediaId); }); }, { threshold: [0.35, 0.6] });
      mediaItems.forEach((media) => observer.observe(media));
    }
    gallery.querySelector('[data-product-thumbs-next]')?.addEventListener('click', (event) => {
      event.preventDefault(); event.stopPropagation(); if (!thumbsList) return;
      const firstThumb = thumbsList.querySelector('.azp-thumb');
      const gap = parseFloat(getComputedStyle(firstThumb || thumbsList).marginBottom || 13) || 13;
      thumbsList.scrollBy({ top: ((firstThumb?.offsetHeight || 66) + gap) * 6, behavior: 'smooth' });
    });
    const injectDimensionsButton = () => {
      const buyButton = section?.querySelector('.product-form-wrapper .product-form__submit');
      if (!buyButton || section.querySelector('.product-dimensions-button')) return false;
      const dimensionsButton = document.createElement('button');
      dimensionsButton.type = 'button'; dimensionsButton.className = 'product-dimensions-button'; dimensionsButton.setAttribute('aria-label', 'Dimensions et capacité');
      dimensionsButton.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 7.5 7.5 4 20 16.5 16.5 20 4 7.5Z"/><path d="m8 6 2 2"/><path d="m11 9 2 2"/><path d="m14 12 2 2"/></svg><span>Dimensions et capacité</span>';
      buyButton.insertAdjacentElement('afterend', dimensionsButton);
      return true;
    };
    normalizeTitleSpacing();
    if (!injectDimensionsButton()) {
      const timer = window.setInterval(() => { if (injectDimensionsButton()) window.clearInterval(timer); }, 120);
      window.setTimeout(() => window.clearInterval(timer), 5000);
    }
  })();
</script>
