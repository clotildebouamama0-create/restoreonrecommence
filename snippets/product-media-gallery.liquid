    #ProductGallery-{{ section_id }}-{{ product_id }} { width: var(--azp-gallery-w) !important; max-width: var(--azp-gallery-w) !important; min-width: var(--azp-gallery-w) !important; margin: 0 !important; padding: 0 !important; display: grid !important; grid-template-columns: var(--azp-thumb-w) var(--azp-media-w) !important; gap: var(--azp-gallery-gap) !important; align-items: start !important; overflow: visible !important; }

