    #shopify-section-{{ section_id }} .product-dimensions-button { width: 100% !important; min-height: 58px !important; border-radius: 0 !important; border: 1px solid #d9d9d9 !important; outline: none !important; box-shadow: none !important; background: #fff !important; color: #000 !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; gap: 12px !important; font-family: 'Founders Grotesk Mono', 'Founders Grotesk Mono Light', 'Courier New', monospace !important; font-size: 13px !important; font-weight: 400 !important; letter-spacing: 0.08em !important; text-decoration: none !important; cursor: pointer !important; }
    #shopify-section-{{ section_id }} .product-dimensions-button,
    #shopify-section-{{ section_id }} .product-dimensions-button *,
    #shopify-section-{{ section_id }} .product-dimensions-button::before,
    #shopify-section-{{ section_id }} .product-dimensions-button::after,
    #shopify-section-{{ section_id }} .product-dimensions-button:hover,
    #shopify-section-{{ section_id }} .product-dimensions-button:focus,
    #shopify-section-{{ section_id }} .product-dimensions-button:focus-visible { border-color: #d9d9d9 !important; outline: none !important; box-shadow: none !important; }
    #shopify-section-{{ section_id }} .product-dimensions-button svg { width: 16px !important; height: 16px !important; stroke-width: 1.7 !important; }
    #shopify-section-{{ section_id }} .accordion-tabs,
