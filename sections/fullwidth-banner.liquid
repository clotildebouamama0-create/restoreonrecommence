{%- liquid
  assign bg_color = section.settings.bg_color
  if bg_color == blank
    assign bg_color = 'transparent'
  endif
  assign link_url = section.settings.link
  assign d_max_height = section.settings.desktop_max_height | default: 0
  assign d_fit = section.settings.desktop_fit | default: 'cover'
-%}

<style>
  #shopify-section-{{ section.id }} {
    background: {{ bg_color }};
  }
  #shopify-section-{{ section.id }} .fwb { margin: 0; padding: 0; line-height: 0; }
  #shopify-section-{{ section.id }} .fwb::before { display: none !important; content: none !important; }
  #shopify-section-{{ section.id }} .fwb,
  #shopify-section-{{ section.id }} .fwb * {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
  {%- if d_max_height > 0 -%}
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .fwb__picture {
      height: {{ d_max_height }}px;
      max-height: {{ d_max_height }}px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: {{ bg_color }};
      overflow: hidden;
    }
    {%- if d_fit == 'stretch' -%}
    #shopify-section-{{ section.id }} .fwb__image {
      width: 100% !important;
      height: 100% !important;
      object-fit: fill !important;
      object-position: center !important;
    }
    {%- else -%}
    #shopify-section-{{ section.id }} .fwb__image {
      width: 100% !important;
      height: 100% !important;
      object-fit: {{ d_fit }} !important;
      object-position: center !important;
    }
    {%- endif -%}
  }
  {%- endif -%}
</style>

<section class="fwb" data-section-id="{{ section.id }}"{% if section.settings.enable_parallax_scroll %} data-parallax="0.22" data-parallax-dir="vertical"{% endif %}>
  {%- if link_url != blank -%}
    <a class="fwb__link" href="{{ link_url }}" aria-label="{{ section.settings.alt_text | default: section.settings.image.alt | default: 'banner' | escape }}">
  {%- endif -%}

  <picture class="fwb__picture">
    {%- if section.settings.image_mobile != blank -%}
      {%- assign m_max = section.settings.image_mobile.width | at_most: 1200 -%}
      <source media="(max-width: 749px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 600 }} 600w, {{ section.settings.image_mobile | image_url: width: 900 }} 900w, {{ section.settings.image_mobile | image_url: width: 1200 }} 1200w"
              sizes="100vw">
    {%- endif -%}

    {%- if section.settings.image != blank -%}
      {%- assign d_max = section.settings.image.width | at_most: 3200 -%}
      {%- assign img_alt = section.settings.alt_text | default: section.settings.image.alt | default: 'banner' | escape -%}
      {{ section.settings.image
        | image_url: width: d_max
        | image_tag:
          loading: 'lazy',
          fetchpriority: 'auto',
          widths: '600,900,1200,1600,2000,2400,2800,3200',
          sizes: '100vw',
          class: 'fwb__image',
          alt: img_alt
      }}
    {%- elsif section.settings.image_mobile != blank -%}
      {%- assign img_alt = section.settings.alt_text | default: section.settings.image_mobile.alt | default: 'banner' | escape -%}
      {{ section.settings.image_mobile
        | image_url: width: 1200
        | image_tag:
          loading: 'lazy',
          class: 'fwb__image',
          alt: img_alt
      }}
    {%- else -%}
      <div class="fwb__placeholder">Aucune image sélectionnée</div>
    {%- endif -%}
  </picture>

  {%- if link_url != blank -%}
    </a>
  {%- endif -%}
</section>

<style>
  .fwb {
    display: block;
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    margin-inline-end: calc(50% - 50vw);
    overflow: hidden;
  }
  .fwb__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .fwb__picture {
    display: block;
    width: 100%;
  }
  .fwb__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .fwb__placeholder {
    width: 100%;
    aspect-ratio: 16 / 6;
    background: #ece9e0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7a7a7a;
    font-family: 'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif;
    font-size: 14px;
  }
</style>

{% schema %}
{
  "name": "Bannière pleine largeur",
  "tag": "section",
  "class": "fullwidth-banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)",
      "info": "Format recommandé : 3200×1100 ou 3912×1344 px. JPG ou WebP optimisé."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile (optionnel)",
      "info": "Plus carrée ou en portrait pour un meilleur rendu mobile. Si vide, l'image desktop sera utilisée."
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Texte alternatif (alt)",
      "info": "Pour le SEO et l'accessibilité."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Lien (optionnel)",
      "info": "Si renseigné, toute la bannière devient cliquable."
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax_scroll",
      "label": "Activer le parallaxe au scroll",
      "default": false
    },
    {
      "type": "header",
      "content": "Taille desktop"
    },
    {
      "type": "range",
      "id": "desktop_max_height",
      "label": "Hauteur max desktop (px)",
      "info": "0 = pleine taille naturelle de l'image. Diminuez pour rendre la bannière plus fine.",
      "min": 0,
      "max": 1100,
      "step": 20,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "desktop_fit",
      "label": "Mode d'affichage desktop",
      "info": "Cover = image remplit 100% largeur, crop haut/bas. Contain = image entière visible, blanc sur côtés si nécessaire. Stretch = étire pour remplir (peut déformer).",
      "options": [
        { "value": "cover", "label": "Cover (remplit largeur, crop haut/bas)" },
        { "value": "contain", "label": "Contain (entière visible)" },
        { "value": "stretch", "label": "Stretch (remplit tout, étire)" }
      ],
      "default": "cover"
    }
  ],
  "presets": [
    {
      "name": "Bannière pleine largeur"
    }
  ]
}
{% endschema %}