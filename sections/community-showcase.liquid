{%- liquid
  assign bg_color = section.settings.bg_color
  if bg_color == blank
    assign bg_color = '#fffcf0'
  endif
  assign text_color = section.settings.text_color
  if text_color == blank
    assign text_color = '#1a1a1a'
  endif
  assign accent_color = section.settings.accent_color
  if accent_color == blank
    assign accent_color = '#7a3fb6'
  endif
  assign muted_color = section.settings.muted_color
  if muted_color == blank
    assign muted_color = '#5a5a5a'
  endif
  assign btn_bg = section.settings.button_bg
  if btn_bg == blank
    assign btn_bg = '#3b1d5c'
  endif
  assign btn_fg = section.settings.button_fg
  if btn_fg == blank
    assign btn_fg = '#ffffff'
  endif
  assign card_radius = section.settings.card_radius | default: 16
  assign blocks_count = section.blocks.size | at_least: 1
-%}

<style>
  #shopify-section-{{ section.id }} {
    --cs-bg: {{ bg_color }};
    --cs-fg: {{ text_color }};
    --cs-accent: {{ accent_color }};
    --cs-muted: {{ muted_color }};
    --cs-btn-bg: {{ btn_bg }};
    --cs-btn-fg: {{ btn_fg }};
    --cs-radius: {{ card_radius }}px;
  }
  #shopify-section-{{ section.id }} .cs::before { display: none !important; content: none !important; }
</style>

<section class="cs slider-section-padding" data-section-id="{{ section.id }}">
  <div class="cs__inner page-width">
    <div class="cs__grid">

      <div class="cs__text">
        {%- if section.settings.show_rating -%}
          <div class="cs__rating">
            <span class="cs__stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.5l2.95 6.36 6.94.79-5.18 4.74 1.46 6.86L12 17.77l-6.17 3.48 1.46-6.86L2.11 9.65l6.94-.79z"/></svg>
              {%- endfor -%}
            </span>
            {%- if section.settings.rating_text != blank -%}
              <span class="cs__rating-text">{{ section.settings.rating_text | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.heading_main != blank
              or section.settings.heading_italic_1 != blank
              or section.settings.heading_middle != blank
              or section.settings.heading_italic_2 != blank
              or section.settings.heading_end != blank -%}
          <div class="cs__heading" role="heading" aria-level="2">
            {%- if section.settings.heading_italic_1 != blank -%}
              <em class="cs__h-italic">{{ section.settings.heading_italic_1 | escape }}</em>
            {%- endif -%}
            {%- if section.settings.heading_main != blank -%}
              <span class="cs__h-main">{{ section.settings.heading_main | escape }}</span>
            {%- endif -%}
            {%- if section.settings.heading_middle != blank -%}
              <span class="cs__h-main">{{ section.settings.heading_middle | escape }}</span>
            {%- endif -%}
            {%- if section.settings.heading_italic_2 != blank -%}
              <em class="cs__h-italic">{{ section.settings.heading_italic_2 | escape }}</em>
            {%- endif -%}
            {%- if section.settings.heading_end != blank -%}
              <span class="cs__h-main">{{ section.settings.heading_end | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="cs__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="cs__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}

        {%- if section.settings.hashtag != blank or section.settings.tiktok_link != blank or section.settings.instagram_link != blank -%}
          <div class="cs__hashtag-row">
            {%- if section.settings.hashtag != blank -%}
              <span class="cs__hashtag">{{ section.settings.hashtag | escape }}</span>
            {%- endif -%}
            {%- if section.settings.tiktok_link != blank or section.settings.instagram_link != blank -%}
              <span class="cs__socials">
                {%- if section.settings.tiktok_link != blank -%}
                  <a class="cs__social" href="{{ section.settings.tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.1 20.1a6.34 6.34 0 0 0 10.86-4.43V8.93a8.16 8.16 0 0 0 4.77 1.52V7a4.85 4.85 0 0 1-1.14-.31z"/>
                    </svg>
                  </a>
                {%- endif -%}
                {%- if section.settings.instagram_link != blank -%}
                  <a class="cs__social" href="{{ section.settings.instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
                      <circle cx="12" cy="12" r="4"/>
                      <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
                    </svg>
                  </a>
                {%- endif -%}
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="cs__actions">
          {%- if section.settings.button_label != blank -%}
            <a class="cs__button" href="{{ section.settings.button_link | default: '#' }}">
              {{- section.settings.button_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="cs__media">
        <div class="cs__viewport">
          <div class="cs__track" data-cs-track>
            {%- for block in section.blocks -%}
              {%- assign cover_alt = block.settings.label | default: 'community video' | escape -%}
              {%- assign has_video_file = false -%}
              {%- if block.settings.video_file != blank -%}{% assign has_video_file = true %}{%- endif -%}
              {%- assign has_video_url = false -%}
              {%- if block.settings.video_url != blank -%}{% assign has_video_url = true %}{%- endif -%}
              {%- assign has_any_video = false -%}
              {%- if has_video_file or has_video_url -%}{% assign has_any_video = true %}{%- endif -%}

              <article class="cs__card" {{ block.shopify_attributes }} data-cs-slide{% if has_any_video %} data-has-video="true"{% endif %}>
                {%- if block.settings.link != blank -%}
                  <a class="cs__card-link" href="{{ block.settings.link }}" aria-label="{{ cover_alt }}">
                {%- endif -%}

                {%- if block.settings.cover_image != blank -%}
                  {{ block.settings.cover_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'cs__card-img', alt: cover_alt, widths: '300,500,700,900' }}
                {%- else -%}
                  <div class="cs__card-img cs__card-img--ph"></div>
                {%- endif -%}

                {%- if has_video_file -%}
                  <video class="cs__card-video"
                         muted loop playsinline preload="metadata"
                         {% if block.settings.cover_image %}poster="{{ block.settings.cover_image | image_url: width: 800 }}"{% endif %}>
                    {%- for source in block.settings.video_file.sources -%}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {%- endfor -%}
                  </video>
                {%- elsif has_video_url -%}
                  <video class="cs__card-video"
                         muted loop playsinline preload="metadata"
                         {% if block.settings.cover_image %}poster="{{ block.settings.cover_image | image_url: width: 800 }}"{% endif %}>
                    <source src="{{ block.settings.video_url }}" type="video/mp4">
                  </video>
                {%- endif -%}

                {%- if block.settings.label != blank -%}
                  <span class="cs__card-label">{{ block.settings.label | escape }}</span>
                {%- endif -%}

                {%- if has_any_video -%}
                  <button type="button" class="cs__card-play cs__card-play--btn" aria-label="Lire la vidéo" data-cs-play>
                    <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                  </button>
                {%- endif -%}

                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </article>
            {%- endfor -%}
          </div>
        </div>

        {%- if blocks_count > 1 -%}
          <div class="cs__nav">
            <button class="cs__arrow cs__arrow--prev" type="button" data-cs-prev aria-label="Précédent">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <div class="cs__dots" data-cs-dots>
              {%- for block in section.blocks -%}
                <button type="button" class="cs__dot{% if forloop.first %} is-active{% endif %}" data-cs-dot="{{ forloop.index0 }}" aria-label="Aller à l'élément {{ forloop.index }}"></button>
              {%- endfor -%}
            </div>
            <button class="cs__arrow cs__arrow--next" type="button" data-cs-next aria-label="Suivant">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .cs {
    background: var(--cs-bg) !important;
    color: var(--cs-fg);
    width: 100%;
  }
  .cs__inner { width: 100%; }
  .cs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: center;
  }
  @media screen and (min-width: 990px) {
    .cs__grid {
      grid-template-columns: minmax(280px, 380px) 1fr;
      gap: 60px;
    }
  }

  .cs__text { display: flex; flex-direction: column; gap: 16px; min-width: 0; }

  .cs__rating { display: inline-flex; align-items: center; gap: 8px; color: var(--cs-accent); }
  .cs__stars { display: inline-flex; gap: 2px; line-height: 0; }
  .cs__stars svg { display: block; }
  .cs__rating-text {
    color: var(--cs-muted);
    font-family: 'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
    font-weight: 500;
  }

  .cs__heading {
    margin: 0;
    font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif !important;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.1;
    color: var(--cs-fg);
    font-weight: 600;
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
  .cs__heading > * { display: inline; }
  .cs__heading > * + * { margin-inline-start: 0.28em; }
  .cs__h-italic {
    font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif !important;
    font-style: italic;
    color: var(--cs-accent);
    font-weight: 500;
  }

  .cs__subheading {
    margin: 0;
    font-family: 'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--cs-fg);
  }
  .cs__description {
    margin: 0;
    font-family: 'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif;
    font-size: 14px;
    line-height: 1.55;
    color: var(--cs-muted);
  }
  .cs__hashtag-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 4px;
  }
  .cs__hashtag {
    font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif !important;
    font-style: italic;
    font-size: 22px;
    line-height: 1;
    color: var(--cs-accent);
  }

  .cs__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .cs__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cs-btn-bg) !important;
    color: var(--cs-btn-fg) !important;
    text-decoration: none;
    font-family: 'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 28px;
    border-radius: 999px;
    transition: filter 150ms ease, transform 150ms ease;
  }
  .cs__button:hover { filter: brightness(0.92); transform: translateY(-1px); }

  .cs__socials { display: inline-flex; align-items: center; gap: 8px; }
  .cs__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: transparent;
    color: var(--cs-accent);
    border: 1px solid var(--cs-accent);
    transition: background 150ms ease, color 150ms ease, transform 150ms ease;
    text-decoration: none;
  }
  .cs__social:hover {
    background: var(--cs-accent);
    color: #ffffff;
    transform: translateY(-1px);
  }

  /* Media / carousel */
  .cs__media { min-width: 0; display: flex; flex-direction: column; gap: 18px; }
  .cs__viewport {
    overflow: hidden;
    width: 100%;
  }
  .cs__track {
    display: flex;
    gap: 12px;
    transition: transform 450ms cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: transform;
    touch-action: pan-y;
  }
  .cs__card {
    position: relative;
    flex: 0 0 calc((100% - 24px) / 3);
    aspect-ratio: 9 / 14;
    border-radius: var(--cs-radius);
    overflow: hidden;
    background: #eee;
  }
  @media screen and (max-width: 989px) {
    .cs__card {
      flex: 0 0 calc((100% - 24px) / 3);
    }
  }
  @media screen and (max-width: 600px) {
    .cs__track { gap: 10px; }
    .cs__card { flex: 0 0 calc((100% - 20px) / 3); }
  }
  .cs__card-link {
    position: absolute;
    inset: 0;
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .cs__card-img,
  .cs__card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cs__card-img--ph {
    background: linear-gradient(135deg, rgba(0,0,0,0.06), rgba(0,0,0,0.02));
  }
  .cs__card-video { opacity: 0; transition: opacity 250ms ease; }
  .cs__card:hover .cs__card-video { opacity: 1; }
  .cs__card-label {
    position: absolute;
    left: 12px;
    bottom: 44px;
    color: #fff;
    font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif !important;
    font-size: 14px;
    line-height: 1.15;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
    z-index: 2;
    max-width: calc(100% - 24px);
  }
  .cs__card-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.92);
    color: #1a1a1a;
    border: 0;
    border-radius: 999px;
    backdrop-filter: blur(2px);
    z-index: 2;
    cursor: pointer;
    transition: opacity 200ms ease, transform 200ms ease, background 200ms ease;
    padding: 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.18);
  }
  .cs__card-play svg {
    width: 22px;
    height: 22px;
    margin-left: 2px;
  }
  .cs__card-play:hover {
    background: #ffffff;
    transform: translate(-50%, -50%) scale(1.06);
  }
  .cs__card.is-playing .cs__card-play { opacity: 0; pointer-events: none; }
  .cs__card.is-playing .cs__card-img { opacity: 0; }
  .cs__card.is-playing .cs__card-video { opacity: 1; }
  .cs__card.is-playing .cs__card-label { display: none; }

  /* Nav (arrows + dots) */
  .cs__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .cs__arrow {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid currentColor;
    background: transparent;
    color: var(--cs-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 150ms, border-color 150ms;
  }
  .cs__arrow:hover { color: var(--cs-accent); border-color: var(--cs-accent); }

  .cs__dots {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cs__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 0;
    background: rgba(0,0,0,0.2);
    cursor: pointer;
    padding: 0;
    transition: background 150ms ease, transform 150ms ease;
  }
  .cs__dot.is-active {
    background: var(--cs-accent);
    transform: scale(1.15);
  }
</style>

<script>
  (function() {
    var SECTION_ID = '{{ section.id }}';
    function init() {
      var root = document.querySelector('#shopify-section-' + SECTION_ID);
      if (!root) return;
      var track = root.querySelector('[data-cs-track]');
      var slides = root.querySelectorAll('[data-cs-slide]');
      var dots = root.querySelectorAll('[data-cs-dot]');
      var prev = root.querySelector('[data-cs-prev]');
      var next = root.querySelector('[data-cs-next]');
      if (!track || slides.length === 0) return;

      var index = 0;
      var visibleCount = 3;

      function getVisibleCount() {
        if (window.innerWidth < 750) return 3;
        return 3;
      }
      function maxIndex() {
        var vc = getVisibleCount();
        return Math.max(0, slides.length - vc);
      }
      function update() {
        if (index < 0) index = 0;
        if (index > maxIndex()) index = maxIndex();
        var firstSlide = slides[0];
        if (!firstSlide) return;
        var rect = firstSlide.getBoundingClientRect();
        var styleTrack = window.getComputedStyle(track);
        var gap = parseFloat(styleTrack.columnGap || styleTrack.gap || '12') || 12;
        var step = rect.width + gap;
        track.style.transform = 'translateX(-' + (index * step) + 'px)';
        dots.forEach(function(d, i) {
          d.classList.toggle('is-active', i === index);
        });
      }

      if (prev) prev.addEventListener('click', function() { index--; update(); });
      if (next) next.addEventListener('click', function() { index++; update(); });
      dots.forEach(function(d) {
        d.addEventListener('click', function() {
          index = parseInt(d.getAttribute('data-cs-dot'), 10) || 0;
          update();
        });
      });
      window.addEventListener('resize', update);

      var startX = null;
      track.addEventListener('touchstart', function(e) {
        if (e.touches && e.touches.length === 1) startX = e.touches[0].clientX;
      });
      track.addEventListener('touchend', function(e) {
        if (startX === null) return;
        var endX = (e.changedTouches && e.changedTouches[0]) ? e.changedTouches[0].clientX : startX;
        var dx = endX - startX;
        if (Math.abs(dx) > 40) {
          if (dx < 0) index++;
          else index--;
          update();
        }
        startX = null;
      });

      setTimeout(update, 50);

      // Play / pause logic for video cards
      slides.forEach(function(slide) {
        var video = slide.querySelector('.cs__card-video');
        var playBtn = slide.querySelector('[data-cs-play]');
        if (!video) return;

        function play() {
          if (video.paused) {
            video.play().catch(function(){});
            slide.classList.add('is-playing');
          } else {
            video.pause();
            slide.classList.remove('is-playing');
          }
        }
        if (playBtn) {
          playBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            play();
          });
        }
        // Play on hover (desktop), pause when leaving
        slide.addEventListener('mouseenter', function() {
          if (window.matchMedia('(hover: hover)').matches) {
            video.play().catch(function(){});
            slide.classList.add('is-playing');
          }
        });
        slide.addEventListener('mouseleave', function() {
          if (window.matchMedia('(hover: hover)').matches) {
            video.pause();
            video.currentTime = 0;
            slide.classList.remove('is-playing');
          }
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('shopify:section:load', function(e) {
      if (e && e.detail && e.detail.sectionId === SECTION_ID) init();
    });
  })();
</script>

{% schema %}
{
  "name": "Communauté vidéo",
  "tag": "section",
  "class": "community-showcase",
  "settings": [
    {
      "type": "header",
      "content": "Bloc texte (gauche)"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Afficher les étoiles + note",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Texte note",
      "default": "Note des clients 4.8/5"
    },
    {
      "type": "text",
      "id": "heading_italic_1",
      "label": "Mot italique (début)",
      "default": "Cool"
    },
    {
      "type": "text",
      "id": "heading_main",
      "label": "Texte (milieu 1)",
      "default": "personnes boivent de la poudre"
    },
    {
      "type": "text",
      "id": "heading_middle",
      "label": "Texte (milieu 2)"
    },
    {
      "type": "text",
      "id": "heading_italic_2",
      "label": "Mot italique (fin)",
      "default": "Baïa"
    },
    {
      "type": "text",
      "id": "heading_end",
      "label": "Texte (fin)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre (gras)",
      "default": "Star des réseaux sociaux, notre poudre est le nouveau must-have de 2026."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Rejoignez le mouvement et préparez vos boissons, lattes et recettes préférés avec la communauté Baïa."
    },
    {
      "type": "text",
      "id": "hashtag",
      "label": "Hashtag (italique)",
      "default": "#baia"
    },
    {
      "type": "header",
      "content": "Bouton"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Essayez maintenant"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
