{%- liquid
  assign target_product = section.settings.product
  assign show_bundle = false

  if request.design_mode
    assign show_bundle = true
  elsif template == 'product' and target_product != blank and product.handle == target_product.handle
    assign show_bundle = true
  endif

  if target_product == blank and template == 'product'
    assign target_product = product
  endif
-%}

{%- if show_bundle and target_product != blank -%}
  {%- render 'bundle-selector-render',
    context_settings: section.settings,
    context_blocks: section.blocks,
    target_product: target_product,
    context_id: section.id,
    is_block: false
  -%}
{%- elsif show_bundle -%}
  <p style="text-align:center;padding:20px;font-family:'Founders Grotesk',sans-serif;color:#7a7a7a;">
    Sélectionne le produit cible dans les réglages de la section.
  </p>
{%- endif -%}

{% schema %}
{
  "name": "Sélecteur de bundle",
  "tag": "section",
  "class": "bundle-selector",
  "enabled_on": {
    "templates": ["product"]
