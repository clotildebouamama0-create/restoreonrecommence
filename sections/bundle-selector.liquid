          "default": 1
        },
        {
          "type": "range",
          "id": "discount_percent",
          "label": "Réduction (%)",
          "min": 0,
          "max": 95,
          "step": 1,
          "default": 0
        },
        {
          "type": "text",
          "id": "top_badge",
          "label": "Badge en haut (optionnel)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre (haut de carte)"
        },
        {
          "type": "image_picker",
          "id": "image",
