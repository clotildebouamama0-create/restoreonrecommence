    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "checkbox",
          "id": "is_default",
          "label": "Sélectionné par défaut",
          "default": false
        },
        {
          "type": "range",
          "id": "quantity",
