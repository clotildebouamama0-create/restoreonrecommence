      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Couleur secondaire (prix barré)",
      "default": "#7a7a7a"
    },
    {
      "type": "color",
      "id": "top_badge_bg",
      "label": "Fond du badge haut",
      "default": "#c4f348"
    },
    {
      "type": "color",
      "id": "top_badge_color",
      "label": "Texte du badge haut",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "bottom_pill_bg",
      "label": "Fond de la pill basse",
      "default": "#c4f348"
    },
    {
      "type": "color",
      "id": "bottom_pill_color",
      "label": "Texte de la pill basse",
