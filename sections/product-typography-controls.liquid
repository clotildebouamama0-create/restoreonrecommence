{%- if request.page_type == 'product' -%}
  <div
    data-product-typography-controls
    data-section-id="{{ section.id }}"
    data-title-desktop="{{ section.settings.title_size_desktop }}"
    data-price-desktop="{{ section.settings.price_size_desktop }}"
    data-description-desktop="{{ section.settings.description_size_desktop }}"
    data-variant-desktop="{{ section.settings.variant_size_desktop }}"
    data-linked-text-desktop="{{ section.settings.linked_text_size_desktop }}"
    data-atc-desktop="{{ section.settings.atc_size_desktop }}"
    data-title-mobile="{{ section.settings.title_size_mobile }}"
    data-price-mobile="{{ section.settings.price_size_mobile }}"
    data-description-mobile="{{ section.settings.description_size_mobile }}"
    data-variant-mobile="{{ section.settings.variant_size_mobile }}"
    data-linked-text-mobile="{{ section.settings.linked_text_size_mobile }}"
    data-tab-mobile="{{ section.settings.tab_size_mobile }}"
    hidden
  ></div>
  <style id="ProductTypographyControls-{{ section.id }}">
    html body.luxury-product {
      --luxury-product-title-size: {{ section.settings.title_size_desktop }}px;
      --luxury-product-price-size: {{ section.settings.price_size_desktop }}px;
      --luxury-product-description-size: {{ section.settings.description_size_desktop }}px;
      --luxury-product-variant-size: {{ section.settings.variant_size_desktop }}px;
      --luxury-linked-colors-text-size: {{ section.settings.linked_text_size_desktop }}px;
      --luxury-product-atc-size: {{ section.settings.atc_size_desktop }}px;
      --luxury-product-title-size-mobile: {{ section.settings.title_size_mobile }}px;
      --luxury-product-price-size-mobile: {{ section.settings.price_size_mobile }}px;
      --luxury-product-description-size-mobile: {{ section.settings.description_size_mobile }}px;
      --luxury-product-variant-size-mobile: {{ section.settings.variant_size_mobile }}px;
      --luxury-linked-colors-text-size-mobile: {{ section.settings.linked_text_size_mobile }}px;
      --luxury-product-tab-size-mobile: {{ section.settings.tab_size_mobile }}px;
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Réglages fiche produit",
  "settings": [
    {
      "type": "paragraph",
      "content": "Contrôle les tailles de la fiche produit. Les tailles mobile sont séparées des tailles desktop."
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Titre desktop",
      "min": 12,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "price_size_desktop",
      "label": "Prix desktop",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "description_size_desktop",
      "label": "Description desktop",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 19
    },
    {
      "type": "range",
      "id": "variant_size_desktop",
      "label": "Cards variantes desktop",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "linked_text_size_desktop",
      "label": "Texte couleurs liées desktop",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "atc_size_desktop",
      "label": "Bouton ajouter au panier desktop",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 19
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Titre mobile",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "price_size_mobile",
      "label": "Prix mobile",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "label": "Description mobile",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "variant_size_mobile",
      "label": "Cards variantes mobile",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "linked_text_size_mobile",
      "label": "Texte couleurs liées mobile",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "tab_size_mobile",
      "label": "Onglets mobile",
      "min": 10,
      "max": 34,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Réglages fiche produit"
    }
  ]
}
{% endschema %}
