{%- liquid
  assign bg = section.settings.bg_color | default: '#f4efe5'
  assign text_color = section.settings.text_color | default: '#1a1a1a'
  assign cta_color = section.settings.cta_color | default: text_color
  assign image_position = section.settings.image_position | default: 'left'
  assign height_d = section.settings.height_desktop | default: 560
  assign height_m = section.settings.height_mobile | default: 420
  assign title_font = section.settings.title_font | default: 'serif'
  assign title_size_d = section.settings.title_size_desktop | default: 48
  assign title_weight = section.settings.title_weight | default: 400
  assign eyebrow = section.settings.eyebrow
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign show_cta_underline = section.settings.cta_underline
-%}

<style>
  #shopify-section-{{ section.id }} {
    background: {{ bg }};
  }
  #shopify-section-{{ section.id }} .its { margin: 0; padding: 0; line-height: 1.4; color: {{ text_color }}; }
  #shopify-section-{{ section.id }} .its::before { display: none !important; content: none !important; }
  #shopify-section-{{ section.id }} .its,
  #shopify-section-{{ section.id }} .its * {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }

  .its {
    display: block;
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    margin-inline-end: calc(50% - 50vw);
    overflow: hidden;
  }
  .its__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    min-height: {{ height_d }}px;
  }
  .its--right .its__grid {
    grid-template-columns: 1fr 1fr;
  }
  .its--right .its__image-wrap { order: 2; }
  .its--right .its__text-wrap { order: 1; }

  .its__image-wrap {
    position: relative;
    overflow: hidden;
    background: #ece9e0;
    min-height: {{ height_d }}px;
  }
  .its__image-wrap img,
  .its__image-wrap picture {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    position: absolute;
    inset: 0;
  }

  .its__text-wrap {
    background: {{ bg }};
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 56px 64px;
    min-height: {{ height_d }}px;
  }
  .its__text-inner {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .its__eyebrow {
    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ text_color }};
    margin: 0;
    align-self: flex-start;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .its__title,
  #shopify-section-{{ section.id }} h2.its__title {
    font-family: {% if title_font == 'mono' or title_font == 'mono-light' %}'Founders Grotesk Mono', ui-monospace, monospace{% elsif title_font == 'serif' or title_font == 'serif-italic' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% else %}'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif{% endif %} !important;
    font-style: {% if title_font == 'serif-italic' %}italic{% else %}normal{% endif %} !important;
    font-size: {{ title_size_d }}px !important;
    font-weight: {% if title_font == 'sans-light' or title_font == 'mono-light' %}300{% else %}{{ title_weight }}{% endif %} !important;
    letter-spacing: {% if title_font == 'mono' or title_font == 'mono-light' %}-0.02em{% else %}-0.01em{% endif %} !important;
    word-spacing: {% if title_font == 'mono' or title_font == 'mono-light' %}-0.1em{% else %}normal{% endif %} !important;
    line-height: 1.05 !important;
    color: {{ text_color }} !important;
    margin: 0 !important;
    text-align: left !important;
  }
  .its__subtitle {
    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.55;
    color: {{ text_color }};
    opacity: 0.78;
    margin: 18px 0 0;
    max-width: 480px;
  }
  .its__cta-wrap {
    align-self: flex-start;
  }
  .its__cta {
    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: {{ cta_color }};
    text-decoration: none;
    display: inline-block;
    padding-bottom: 3px;
    {% if show_cta_underline %}border-bottom: 1px solid {{ cta_color }};{% endif %}
    transition: opacity 200ms ease;
  }
  .its__cta:hover {
    opacity: 0.65;
  }

  /* Mobile: stack vertically */
  @media screen and (max-width: 749px) {
    .its__grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .its--right .its__image-wrap { order: 1; }
    .its--right .its__text-wrap { order: 2; }
    .its__image-wrap {
      min-height: 0;
      height: {{ height_m }}px;
    }
    .its__text-wrap {
      min-height: 0;
      padding: 40px 28px;
      gap: 32px;
    }
    .its__title {
      font-size: clamp(28px, 8vw, 40px);
    }
    .its__subtitle {
      font-size: 14px;
      margin-top: 14px;
    }
  }
</style>

<section class="its its--{{ image_position }}" data-section-id="{{ section.id }}">
  <div class="its__grid">
    <div class="its__image-wrap">
      {%- if section.settings.image != blank -%}
        {%- assign d_w = section.settings.image.width | at_most: 1800 -%}
        {%- assign img_alt = section.settings.image.alt | default: title | default: 'image' | escape -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 750w, {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w" sizes="100vw">
          {%- endif -%}
          {{ section.settings.image | image_url: width: d_w | image_tag:
              loading: 'lazy',
              widths: '600,900,1200,1500,1800',
              sizes: '50vw',
              alt: img_alt
          }}
        </picture>
      {%- else -%}
        <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:#888;font-size:14px;">
          Sélectionnez une image
        </div>
      {%- endif -%}
    </div>

    <div class="its__text-wrap">
      <div class="its__text-eyebrow">
        {%- if eyebrow != blank -%}
          <p class="its__eyebrow">{{ eyebrow | escape }}</p>
        {%- endif -%}
      </div>

      <div class="its__text-inner">
        {%- if title != blank -%}
          <h2 class="its__title">{{ title }}</h2>
        {%- endif -%}
        {%- if subtitle != blank -%}
          <p class="its__subtitle">{{ subtitle }}</p>
        {%- endif -%}
      </div>

      <div class="its__cta-wrap">
        {%- if cta_text != blank -%}
          {%- if cta_link != blank -%}
            <a href="{{ cta_link }}" class="its__cta">{{ cta_text | escape }}</a>
          {%- else -%}
            <span class="its__cta">{{ cta_text | escape }}</span>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image + texte (split)",
  "tag": "section",
  "class": "image-text-split",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)",
      "info": "Format vertical recommandé (ex: 1200×1400 px) car elle prend toute la hauteur de la moitié gauche."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile (optionnel)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position de l'image",
      "options": [
        { "value": "left", "label": "À gauche" },
        { "value": "right", "label": "À droite" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Contenu (côté texte)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre (eyebrow)",
      "default": "SS18 ACCESSORIES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Le sac Chiquito"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Police du titre",
      "options": [
        { "value": "serif", "label": "Serif (Cormorant Garamond)" },
        { "value": "serif-italic", "label": "Serif Italique" },
        { "value": "sans", "label": "Founders Grotesk" },
        { "value": "sans-light", "label": "Founders Grotesk Light" },
        { "value": "mono", "label": "Founders Grotesk Mono" },
        { "value": "mono-light", "label": "Founders Grotesk Mono Light" }
      ],
      "default": "serif"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Taille titre (desktop)",
      "min": 20,
      "max": 100,
      "step": 1,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_weight",
      "label": "Graisse du titre",
      "info": "300 = light, 400 = regular, 500 = medium, 700 = bold, 900 = black",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre (optionnel)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du CTA",
      "default": "Shop bags"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du CTA"
    },
    {
      "type": "checkbox",
      "id": "cta_underline",
      "label": "Soulignement du CTA",
      "default": true
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond (côté texte)",
      "default": "#f4efe5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Couleur du CTA (laisser vide = couleur du texte)"
    },
    {
      "type": "header",
      "content": "Taille"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur desktop",
      "min": 400,
      "max": 900,
      "step": 20,
      "default": 560,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Hauteur image mobile",
      "min": 300,
      "max": 700,
      "step": 20,
      "default": 420,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Image + texte (split)"
    }
  ]
}
{% endschema %}
