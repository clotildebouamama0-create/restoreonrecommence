{%- liquid
  assign title_font_family = "'Founders Grotesk','Founders Grotesk Regular',Arial,sans-serif"
  case section.settings.title_font
    when 'mono'
      assign title_font_family = "'Founders Grotesk Mono','Founders Grotesk Mono Light','Founders Grotesk Mono Regular','Courier New',monospace"
    when 'system_sans'
      assign title_font_family = "Arial,Helvetica,sans-serif"
    when 'serif'
      assign title_font_family = "Georgia,'Times New Roman',serif"
    when 'system_mono'
      assign title_font_family = "'Courier New',Courier,monospace"
  endcase

  assign desc_font_family = "'Founders Grotesk','Founders Grotesk Regular',Arial,sans-serif"
  case section.settings.desc_font
    when 'mono'
      assign desc_font_family = "'Founders Grotesk Mono','Founders Grotesk Mono Light','Founders Grotesk Mono Regular','Courier New',monospace"
    when 'system_sans'
      assign desc_font_family = "Arial,Helvetica,sans-serif"
    when 'serif'
      assign desc_font_family = "Georgia,'Times New Roman',serif"
    when 'system_mono'
      assign desc_font_family = "'Courier New',Courier,monospace"
  endcase

  assign card_title_font_family = "'Founders Grotesk','Founders Grotesk Regular',Arial,sans-serif"
  case section.settings.card_title_font
    when 'mono'
      assign card_title_font_family = "'Founders Grotesk Mono','Founders Grotesk Mono Light','Founders Grotesk Mono Regular','Courier New',monospace"
    when 'system_sans'
      assign card_title_font_family = "Arial,Helvetica,sans-serif"
    when 'serif'
      assign card_title_font_family = "Georgia,'Times New Roman',serif"
    when 'system_mono'
      assign card_title_font_family = "'Courier New',Courier,monospace"
  endcase

  assign card_text_font_family = "'Founders Grotesk','Founders Grotesk Regular',Arial,sans-serif"
  case section.settings.card_text_font
    when 'mono'
      assign card_text_font_family = "'Founders Grotesk Mono','Founders Grotesk Mono Light','Founders Grotesk Mono Regular','Courier New',monospace"
    when 'system_sans'
      assign card_text_font_family = "Arial,Helvetica,sans-serif"
    when 'serif'
      assign card_text_font_family = "Georgia,'Times New Roman',serif"
    when 'system_mono'
      assign card_text_font_family = "'Courier New',Courier,monospace"
  endcase
-%}

<style>
  #shopify-section-{{ section.id }} {
    --dcg-bg: {{ section.settings.section_bg }};
    --dcg-card-bg: {{ section.settings.card_bg }};
    --dcg-title-color: {{ section.settings.title_color }};
    --dcg-desc-color: {{ section.settings.desc_color }};
    --dcg-card-title-color: {{ section.settings.card_title_color }};
    --dcg-card-text-color: {{ section.settings.card_text_color }};
    --dcg-title-font: {{ title_font_family }};
    --dcg-desc-font: {{ desc_font_family }};
    --dcg-card-title-font: {{ card_title_font_family }};
    --dcg-card-text-font: {{ card_text_font_family }};
    --dcg-title-size: {{ section.settings.title_size }}px;
    --dcg-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --dcg-title-weight: {{ section.settings.title_weight }};
    --dcg-desc-size: {{ section.settings.desc_size }}px;
    --dcg-desc-size-mobile: {{ section.settings.desc_size_mobile }}px;
    --dcg-desc-weight: {{ section.settings.desc_weight }};
    --dcg-card-title-size: {{ section.settings.card_title_size }}px;
    --dcg-card-title-size-mobile: {{ section.settings.card_title_size_mobile }}px;
    --dcg-card-title-weight: {{ section.settings.card_title_weight }};
    --dcg-card-text-size: {{ section.settings.card_text_size }}px;
    --dcg-card-text-size-mobile: {{ section.settings.card_text_size_mobile }}px;
    --dcg-card-text-weight: {{ section.settings.card_text_weight }};
    --dcg-section-max-width: {{ section.settings.section_max_width }}px;
    --dcg-padding-top: {{ section.settings.padding_top }}px;
    --dcg-padding-bottom: {{ section.settings.padding_bottom }}px;
    --dcg-padding-x: {{ section.settings.padding_x }}px;
    --dcg-header-margin-bottom: {{ section.settings.header_margin_bottom }}px;
    --dcg-title-margin-bottom: {{ section.settings.title_margin_bottom }}px;
    --dcg-grid-gap: {{ section.settings.grid_gap }}px;
    --dcg-card-radius: {{ section.settings.card_radius }}px;
    --dcg-image-height: {{ section.settings.image_height }}px;
    --dcg-content-padding-y: {{ section.settings.content_padding_y }}px;
    --dcg-content-padding-x: {{ section.settings.content_padding_x }}px;
    --dcg-card-title-margin-bottom: {{ section.settings.card_title_margin_bottom }}px;
    --dcg-card-min-height: {{ section.settings.card_min_height }}px;
  }

  #shopify-section-{{ section.id }} .daily-card-grid {
    background: var(--dcg-bg);
    padding: var(--dcg-padding-top) var(--dcg-padding-x) var(--dcg-padding-bottom);
  }

  #shopify-section-{{ section.id }} .daily-card-grid__inner {
    width: 100%;
    max-width: var(--dcg-section-max-width);
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .daily-card-grid__header {
    margin: 0 auto var(--dcg-header-margin-bottom);
    max-width: {{ section.settings.header_max_width }}px;
    text-align: {{ section.settings.header_alignment }};
  }

  #shopify-section-{{ section.id }} .daily-card-grid__title {
    margin: 0 0 var(--dcg-title-margin-bottom);
    color: var(--dcg-title-color);
    font-family: var(--dcg-title-font);
    font-size: var(--dcg-title-size);
    font-weight: var(--dcg-title-weight);
    line-height: {{ section.settings.title_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.title_letter_spacing | divided_by: 1000.0 }}em;
    text-transform: {{ section.settings.title_transform }};
  }

  #shopify-section-{{ section.id }} .daily-card-grid__description {
    margin: 0;
    color: var(--dcg-desc-color);
    font-family: var(--dcg-desc-font);
    font-size: var(--dcg-desc-size);
    font-weight: var(--dcg-desc-weight);
    line-height: {{ section.settings.desc_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.desc_letter_spacing | divided_by: 1000.0 }}em;
  }

  #shopify-section-{{ section.id }} .daily-card-grid__items {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: var(--dcg-grid-gap);
  }

  #shopify-section-{{ section.id }} .daily-card-grid__card {
    overflow: hidden;
    min-height: var(--dcg-card-min-height);
    border-radius: var(--dcg-card-radius);
    background: var(--dcg-card-bg);
    color: var(--dcg-card-text-color);
    {% if section.settings.card_border_width > 0 %}border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};{% endif %}
    {% if section.settings.card_shadow %}box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);{% endif %}
  }

  #shopify-section-{{ section.id }} .daily-card-grid__media {
    width: 100%;
    height: var(--dcg-image-height);
    background: {{ section.settings.placeholder_bg }};
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .daily-card-grid__media img,
  #shopify-section-{{ section.id }} .daily-card-grid__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_position }};
  }

  #shopify-section-{{ section.id }} .daily-card-grid__placeholder {
    background: {{ section.settings.placeholder_bg }};
  }

  #shopify-section-{{ section.id }} .daily-card-grid__content {
    padding: var(--dcg-content-padding-y) var(--dcg-content-padding-x);
  }

  #shopify-section-{{ section.id }} .daily-card-grid__card-title {
    margin: 0 0 var(--dcg-card-title-margin-bottom);
    color: var(--dcg-card-title-color);
    font-family: var(--dcg-card-title-font);
    font-size: var(--dcg-card-title-size);
    font-weight: var(--dcg-card-title-weight);
    line-height: {{ section.settings.card_title_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.card_title_letter_spacing | divided_by: 1000.0 }}em;
    text-transform: {{ section.settings.card_title_transform }};
  }

  #shopify-section-{{ section.id }} .daily-card-grid__card-text {
    margin: 0;
    color: var(--dcg-card-text-color);
    font-family: var(--dcg-card-text-font);
    font-size: var(--dcg-card-text-size);
    font-weight: var(--dcg-card-text-weight);
    line-height: {{ section.settings.card_text_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.card_text_letter_spacing | divided_by: 1000.0 }}em;
  }

  #shopify-section-{{ section.id }} .daily-card-grid__card-text p { margin: 0; }
  #shopify-section-{{ section.id }} .daily-card-grid__card-text p + p { margin-top: 0.8em; }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .daily-card-grid__items {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .daily-card-grid {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_x_mobile }}px;
      padding-right: {{ section.settings.padding_x_mobile }}px;
    }

    #shopify-section-{{ section.id }} .daily-card-grid__header {
      margin-bottom: {{ section.settings.header_margin_bottom_mobile }}px;
      text-align: {{ section.settings.header_alignment_mobile }};
    }

    #shopify-section-{{ section.id }} .daily-card-grid__title {
      font-size: var(--dcg-title-size-mobile);
      margin-bottom: {{ section.settings.title_margin_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .daily-card-grid__description { font-size: var(--dcg-desc-size-mobile); }

    #shopify-section-{{ section.id }} .daily-card-grid__items {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
      gap: {{ section.settings.grid_gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .daily-card-grid__media { height: {{ section.settings.image_height_mobile }}px; }
    #shopify-section-{{ section.id }} .daily-card-grid__content { padding: {{ section.settings.content_padding_y_mobile }}px {{ section.settings.content_padding_x_mobile }}px; }
    #shopify-section-{{ section.id }} .daily-card-grid__card-title { font-size: var(--dcg-card-title-size-mobile); margin-bottom: {{ section.settings.card_title_margin_bottom_mobile }}px; }
    #shopify-section-{{ section.id }} .daily-card-grid__card-text { font-size: var(--dcg-card-text-size-mobile); }
  }
</style>

<section class="daily-card-grid" {{ section.shopify_attributes }}>
  <div class="daily-card-grid__inner">
    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="daily-card-grid__header">
        {%- if section.settings.title != blank -%}
          <{{ section.settings.title_tag }} class="daily-card-grid__title">{{ section.settings.title | escape }}</{{ section.settings.title_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="daily-card-grid__description">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="daily-card-grid__items">
      {%- for block in section.blocks -%}
        <article class="daily-card-grid__card" {{ block.shopify_attributes }}>
          <div class="daily-card-grid__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw', widths: '360, 540, 720, 900, 1200' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'daily-card-grid__placeholder' }}
            {%- endif -%}
          </div>
          <div class="daily-card-grid__content">
            {%- if block.settings.title != blank -%}
              <h3 class="daily-card-grid__card-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="daily-card-grid__card-text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cartes lifestyle",
  "settings": [
    {"type": "header", "content": "Contenu"},
    {"type": "text", "id": "title", "label": "Titre", "default": "Overal. Elke dag."},
    {"type": "richtext", "id": "description", "label": "Description"},
    {"type": "select", "id": "title_tag", "label": "Balise du titre", "default": "h2", "options": [{"value": "h1", "label": "H1"}, {"value": "h2", "label": "H2"}, {"value": "h3", "label": "H3"}, {"value": "div", "label": "Div"}]},

