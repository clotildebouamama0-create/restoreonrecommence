<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      {%- assign media_ratio = section.settings.media_size | divided_by: 50.0 -%}
      --product-grid: auto / minmax(0, {{ media_ratio }}fr) minmax(0, {{ 2.0 | minus: media_ratio }}fr);
    }
  }

  {%- assign first_media = product.selected_or_first_available_variant.featured_media | default: product.media.first -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --aspect-ratio: {{ first_media.aspect_ratio }};
    }
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --aspect-ratio: {{ first_media.aspect_ratio }};
    }
  }
</style>

{%- liquid
  assign product_form_id = 'ProductForm-' | append: section.id | append: '-' | append: product.id
  assign media_count = product.media.size
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  assign icon_list_block = section.blocks | where: 'type', 'icon_list' | first
-%}

{%- if first_3d_model -%}
  {{ 'model-viewer.css' | asset_url | stylesheet_tag }}
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  />
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  />
{%- endif -%}

{%- if product.quantity_price_breaks_configured? -%}
  {{ 'volume-pricing.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'volume-pricing.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if icon_list_block -%}
  {%- capture icon_list_render -%}
    {%- if settings.product_icon_list_metafield != blank -%}
      {%- liquid
        assign metafield_parts = settings.product_icon_list_metafield | split: '.'
        assign metafield_namespace = metafield_parts | first
        assign metafield_key = metafield_parts | last
        assign metafield = product.metafields[metafield_namespace][metafield_key]
      -%}
      {%- if metafield.value != blank and metafield.list? -%}
        <div class="product__highlights{% if icon_list_block.settings.heading != blank %} with-heading flex flex-col gap-5 relative{% endif %}{% if icon_list_block.settings.show_below_media %} below-media{% endif %}" {{ icon_list_block.shopify_attributes }}>
          {%- if icon_list_block.settings.heading != blank -%}
            <p class="font-medium leading-tight md:text-lg">{{ icon_list_block.settings.heading | escape }}</p>
          {%- endif -%}
          <scroll-shadow class="product-card__spec block overflow-hidden">
            <div class="product-card__icons flex flex-nowrap{% unless icon_list_block.settings.enable_carousel %} lg:flex-wrap{% endunless %}" is="icons-carousel" tabindex="0">
              {%- for item in metafield.value -%}
                <div class="product-card__icon shrink-0">
                  <div class="flex flex-col items-center md:flex-row md:items-start gap-2">
                    {%- if item.icon.value != blank -%}
                      {%- assign icon_alt = item.icon.value.alt | default: item.title | escape -%}
                      {%- assign max_width = item.icon.value.width -%}
                      <figure class="shrink-0 media media--transparent relative inline-block">
                        {%- capture sizes -%}32px{%- endcapture -%}
                        {%- capture widths -%}{{ 32 | times: 1.5 | at_most: max_width | round }}, {{ 32 | times: 2 | at_most: max_width }}, {{ 32 | times: 3 | at_most: max_width }}{%- endcapture -%}
                        {{- item.icon.value | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: icon_alt, class: 'w-full h-full', is: 'lazy-image' -}}
                      </figure>
                    {%- endif -%}
                    <div class="flex flex-col items-center md:items-start gap-1 text-center md:text-left text-sm font-medium leading-none">
                      {{- item.title -}}
                      {%- if item.description != blank -%}
                        <p class="text-opacity font-normal text-xs leading-tight">{{ item.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <template>
              <slot></slot>
              <s dir="{% render 'direction' %}" style="--t: 0;--b: 0;--l: 0;--r: 0;">
                <span class="l"></span>
                <span class="r"></span>
              </s>
              <style>
                :host{display:inline-block;position:relative}:host([hidden]){display:none}
                s{position:absolute;inset:0;pointer-events:none;}
                s span{position:absolute;inset-block:0;width:clamp(var(--sp-12),4.73vw,var(--sp-23));opacity:0;transition:opacity var(--animation-short);}
                s .l{inset-inline-start:0;opacity:var(--l);background:linear-gradient(90deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s .r{inset-inline-end:0;opacity:var(--r);background:linear-gradient(270deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s[dir=rtl] :is(.icon-chevron-left,.icon-chevron-right){transform:scaleX(-1);}
              </style>
            </template>
          </scroll-shadow>
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- endcapture -%}
{%- endif  -%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if media_count > 0 %}{% if section.settings.full_width %} page-width--full{% endif %}{% else %} page-width--narrow{% endif %} relative">
    <div class="featured-product product product--{{ section.settings.gallery_layout }}{% if media_count == 0 %} no-media{% endif %} flex flex-col items-start lg:grid gap-5 w-full relative">
      {%- if media_count > 0 -%}
        <div class="product__gallery-container{% if section.settings.enable_sticky_info %} lg:sticky{% endif %} flex flex-col gap-0 md:gap-8 relative w-full">
          {%- render 'product-media-gallery',
            product: product,
            product_id: product.id,
            section_id: section.id,
            gallery_layout: section.settings.gallery_layout,
            thumbnail_position: section.settings.thumbnail_position,
            image_ratio: section.settings.image_ratio,
            image_ratio_mobile: section.settings.image_ratio_mobile,
            image_zoom: section.settings.image_zoom,
            image_fill: settings.product_image_fill,
            mobile_layout: section.settings.mobile_layout,
            mobile_thumbnail: section.settings.mobile_thumbnail,
            hide_variants: section.settings.hide_variants,
            enable_video_autoplay: section.settings.enable_video_autoplay,
            enable_video_looping: section.settings.enable_video_looping,
            first_3d_model: first_3d_model,
            product_form_id: product_form_id
          -%}

          {%- liquid
            if icon_list_block and icon_list_block.settings.show_below_media
              echo icon_list_render
            endif
          -%}
        </div>
      {%- endif -%}

      <product-info
        id="ProductInfo-{{ section.id }}-{{ product.id }}"
        class="product__info{% if section.settings.enable_sticky_info %} lg:sticky{% endif %} block w-full"
        data-animate="fade-up"
        data-immediate
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
        data-product-url="{{ product.url }}"
        data-update-url="true"
        form="{{ product_form_id }}"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {%- render block -%}

            {%- when 'breadcrumb' -%}
              {%- render 'product-breadcrumb', product: product, block: block -%}

            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                {%- if block.settings.text != product.vendor -%}
                  {%- liquid
                    assign prev_index = forloop.index0 | minus: 1
                    assign prev_block = section.blocks[prev_index]
                    assign next_index = forloop.index0 | plus: 1
                    assign next_block = section.blocks[next_index]
  
                    if prev_block.type == 'sticky_buy_button'
                      assign prev_index = prev_index | minus: 1
                      assign prev_block = section.blocks[prev_index]
                    endif
  
                    if next_block.type == 'sticky_buy_button'
                      assign next_index = next_index | plus: 1
                      assign next_block = section.blocks[next_index]
                    endif
  
                    if prev_block.type != 'text'
                      assign block_index = 1
                    else
                      assign block_index = block_index | plus: 1
                    endif
  
                    assign modulo = block_index | modulo: 2
                  -%}
                  <div class="product__text{% if modulo == 0 %} even{% endif %}{% if prev_block.type != 'text' %} first{% endif %}{% if next_block.type != 'text' %} last{% endif %}" {{ block.shopify_attributes }}>
                    <div class="product__text-inner flex items-center gap-2d5">
                      {%- if block.settings.icon_image != blank -%}
                        {%- liquid
                          if block.settings.iwidth == 'fit'
                            assign icon_width = block.settings.icon_image.width
                          else
                            assign icon_width = block.settings.icon_width
                          endif
                          assign image_alt = block.settings.icon_image.alt | default: block.settings.accessibility_info | escape
                          assign image_alt = image_alt | default: block.settings.text | escape
                          assign max_width = block.settings.icon_image.width
                        -%}
                        <figure class="media media--transparent relative inline-block">
                          {%- capture sizes -%}{{ icon_width }}px{%- endcapture -%}
                          {%- capture widths -%}{{ icon_width | times: 1.5 | at_most: max_width | round }}, {{ icon_width | times: 2 | at_most: max_width }}, {{ icon_width | times: 3 | at_most: max_width }}{%- endcapture -%}
                          {{- block.settings.icon_image | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: image_alt, class: 'image-fit' -}}
                        </figure>
                      {%- elsif block.settings.icon != 'none' -%}
                        {%- liquid
                          if block.settings.iwidth == 'fit'
                            render 'icon-guarantee', icon: block.settings.icon, size: 'lg', class: 'inline-block stroke-1'
                          else
                            render 'icon-guarantee', icon: block.settings.icon, size: 'custom', class: 'inline-block stroke-1', width: block.settings.icon_width
                          endif
                        -%}
                      {%- endif -%}
                      <p class="rte {{ block.settings.text_size }} leading-tight">{{ block.settings.text }}</p>
                    </div>
                  </div>
                {%- else -%}
                  <p class="product__vendor {{ block.settings.text_size }}" {{ block.shopify_attributes }}>
                    <a href="{{ product.vendor | url_for_vendor }}" title="{{ product.vendor | escape }}" class="reversed-link">
                      <span class="sr-only">{{ 'general.accessibility.vendor' | t }}</span>
                      {{- product.vendor -}}
                    </a>
                  </p>
                {%- endif -%}
              {%- endif -%}

            {%- when 'sku' -%}
              <p class="product__sku" id="Sku-{{ section.id }}-{{ product.id }}" {{ block.shopify_attributes }}>
                {{- product.selected_or_first_available_variant.sku -}}
              </p>

            {%- when 'badges' -%}
              <div class="product__badges" id="Badges-{{ section.id }}-{{ product.id }}" {{ block.shopify_attributes }}>
                {%- render 'product-badges', product: product, use_variant: true, show_sold_out: block.settings.show_sold_out, show_save_amount: block.settings.show_save_amount, save_type: block.settings.save_type, class: 'flex flex-wrap gap-3' -%}
              </div>

            {%- when 'description' -%}
              <div class="product__text rte {{ block.settings.text_size }}" {{ block.shopify_attributes }}>
                {{- product.description -}}
              </div>

            {%- when 'payment_badges' -%}
              {%- liquid
                assign pb_text = block.settings.secure_text
                if pb_text == blank
                  assign pb_text = 'Secure Checkout'
                endif
                assign pb_color = block.settings.text_color
                if pb_color == blank
                  assign pb_color = '#7a7a7a'
                endif
              -%}
              <style>
                #PaymentBadges-{{ block.id }} { --pb-color: {{ pb_color }}; }
              </style>
              <div class="payment-badges" id="PaymentBadges-{{ block.id }}" {{ block.shopify_attributes }}>
                {%- if block.settings.show_visa -%}
                  <img class="pb-icon" loading="lazy" alt="Visa" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/2c2bf.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_mastercard -%}
                  <img class="pb-icon" loading="lazy" alt="Mastercard" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/cd169.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_amex -%}
                  <img class="pb-icon" loading="lazy" alt="American Express" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/b34cb.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_cb -%}
                  <img class="pb-icon" loading="lazy" alt="Carte Bancaire" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/f6e0a.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_apple_pay -%}
                  <img class="pb-icon" loading="lazy" alt="Apple Pay" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/6620d.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_paypal -%}
                  <img class="pb-icon" loading="lazy" alt="PayPal" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/4e117.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_klarna -%}
                  <img class="pb-icon" loading="lazy" alt="Klarna" src="https://cdn.shopify.com/shopifycloud/admin-ui-foundations/payment-icons/274d1.svg" width="48" height="32">
                {%- endif -%}
                {%- if block.settings.show_secure_text -%}
                  <span class="pb-secure">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                      <path d="M12 3l8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4z"/>
                      <path d="M9 12.5l2 2 4-4"/>
                    </svg>
                    <span>{{ pb_text | escape }}</span>
                  </span>
                {%- endif -%}
              </div>

            {%- when 'accordion_tabs' -%}
              {%- liquid
                assign tabs_text_color = block.settings.tabs_text_color
                if tabs_text_color == blank
                  assign tabs_text_color = '#1a1a1a'
                endif
                assign tabs_border_color = block.settings.tabs_border_color
                if tabs_border_color == blank
                  assign tabs_border_color = '#dad3c5'
                endif
              -%}
              <style>
                #AccordionTabs-{{ block.id }} {
                  --at-text: {{ tabs_text_color }};
                  --at-border: {{ tabs_border_color }};
                }
              </style>
              <div class="accordion-tabs" id="AccordionTabs-{{ block.id }}" {{ block.shopify_attributes }}>
                {%- for i in (1..6) -%}
                  {%- assign t_key = 'tab_' | append: i | append: '_title' -%}
                  {%- assign c_key = 'tab_' | append: i | append: '_content' -%}
                  {%- assign t_title = block.settings[t_key] -%}
                  {%- assign t_content = block.settings[c_key] -%}
                  {%- if t_title != blank or t_content != blank -%}
                    <details class="accordion-tabs__item" {% if i == 1 and block.settings.open_first %}open{% endif %}>
                      <summary class="accordion-tabs__summary">
                        <span class="accordion-tabs__title">{{ t_title | escape }}</span>
                        <span class="accordion-tabs__icon" aria-hidden="true">
                          <svg class="accordion-tabs__icon-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <line x1="12" y1="5" x2="12" y2="19"/>
                          </svg>
                          <svg class="accordion-tabs__icon-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                          </svg>
                        </span>
                      </summary>
                      <div class="accordion-tabs__content rte">
                        {{ t_content }}
                      </div>
                    </details>
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- when 'feature_pills' -%}
              {%- liquid
                assign pill_bg = block.settings.pill_bg
                if pill_bg == blank
                  assign pill_bg = '#f5e9ec'
                endif
                assign pill_color = block.settings.pill_color
                if pill_color == blank
                  assign pill_color = '#1a1a1a'
                endif
              -%}
              <style>
                #FeaturePills-{{ block.id }} {
                  --fp-bg: {{ pill_bg }};
                  --fp-color: {{ pill_color }};
                }
              </style>
              <div class="feature-pills" id="FeaturePills-{{ block.id }}" {{ block.shopify_attributes }}>
                {%- for i in (1..6) -%}
                  {%- assign pill_key = 'pill_' | append: i -%}
                  {%- assign pill_value = block.settings[pill_key] -%}
                  {%- if pill_value != blank -%}
                    <span class="feature-pill">{{ pill_value | escape }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- when 'linked_colors' -%}
              {%- liquid
                assign lc_label = block.settings.label
                if lc_label == blank
                  assign lc_label = 'Couleur'
                endif
                assign lc_active_color = block.settings.active_color
                if lc_active_color == blank
                  assign lc_active_color = '#111111'
                endif
                assign lc_bg_color = block.settings.bg_color
                if lc_bg_color == blank
                  assign lc_bg_color = '#f3f3f3'
                endif
                assign lc_text_color = block.settings.text_color
                if lc_text_color == blank
                  assign lc_text_color = '#1a1a1a'
                endif
                assign lc_muted_color = block.settings.muted_color
                if lc_muted_color == blank
                  assign lc_muted_color = '#7a7a7a'
                endif
                assign lc_thumb_size = block.settings.thumb_size | default: 56
                assign lc_show_current_name = block.settings.show_current_name
                assign lc_layout = block.settings.layout | default: 'row'

                # Try every common metafield key combination since Shopify rewrites dots to underscores
                # when the user names a metafield "custom.xxx".
                assign mf_key = block.settings.metafield_key
                if mf_key == blank
                  assign mf_key = 'linked_colors'
                endif
                assign linked_list = product.metafields.custom[mf_key].value
                if linked_list == blank
                  assign linked_list = product.metafields.custom.linked_colors.value
                endif
                if linked_list == blank
                  assign linked_list = product.metafields.custom.custom_linked_colors.value
                endif
                if linked_list == blank
                  assign linked_list = product.metafields.custom.linkedcolors.value
                endif
                if linked_list == blank
                  assign linked_list = product.metafields.custom.couleurs_liees.value
                endif
                if linked_list == blank
                  assign linked_list = product.metafields.custom.colors.value
                endif
                if linked_list == blank
                  assign linked_list = product.metafields.custom.color_variants.value
                endif
                if linked_list == blank
                  assign linked_list = product.metafields.custom.variation_products.value
                endif
              -%}
              {%- comment -%} Always render the wrapper so the editor block stays visible and lets the user debug. {%- endcomment -%}
                <style>
                  #LinkedColors-{{ block.id }} {
                    --lc-bg: {{ lc_bg_color }};
                    --lc-active: {{ lc_active_color }};
                    --lc-text: {{ lc_text_color }};
                    --lc-muted: {{ lc_muted_color }};
                    --lc-size: {{ lc_thumb_size }}px;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__wrap {
                    display: {% if lc_layout == 'inline' %}grid{% else %}flex{% endif %};
                    {% if lc_layout == 'inline' %}
                    grid-template-columns: auto 1fr;
                    align-items: center;
                    gap: 24px;
                    {% else %}
                    flex-direction: column;
                    gap: 12px;
                    align-items: flex-start;
                    {% endif %}
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__header {
                    display: flex;
                    flex-direction: column;
                    gap: 2px;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__label {
                    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
                    font-size: 13px;
                    font-weight: 600;
                    letter-spacing: 0.04em;
                    color: var(--lc-text);
                    margin: 0;
                    line-height: 1.3;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__current {
                    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
                    font-size: 12.5px;
                    font-weight: 400;
                    color: var(--lc-muted);
                    margin: 0;
                    line-height: 1.3;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__list {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 8px;
                    list-style: none;
                    padding: 0;
                    margin: 0;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__item {
                    list-style: none;
                    margin: 0;
                    padding: 0;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__thumb {
                    display: block;
                    width: var(--lc-size);
                    height: var(--lc-size);
                    background: var(--lc-bg);
                    position: relative;
                    overflow: hidden;
                    text-decoration: none;
                    border: 1.5px solid transparent;
                    border-radius: 4px;
                    transition: border-color 200ms ease;
                    cursor: pointer;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__thumb:hover {
                    border-color: rgba(0,0,0,0.18);
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__thumb.is-active {
                    border-color: var(--lc-active);
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__thumb img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    object-position: center;
                    display: block;
                    position: absolute;
                    inset: 0;
                  }
                  #LinkedColors-{{ block.id }} .linked-colors__thumb-placeholder {
                    width: 100%;
                    height: 100%;
                    display: block;
                    background: var(--lc-bg);
                  }
                </style>
                <div class="linked-colors" id="LinkedColors-{{ block.id }}" {{ block.shopify_attributes }}>
                  <div class="linked-colors__wrap">
                    <div class="linked-colors__header">
                      <p class="linked-colors__label">{{ lc_label | escape }}</p>
                      {%- if lc_show_current_name -%}
                        <p class="linked-colors__current">{{ product.title | escape }}</p>
                      {%- endif -%}
                    </div>
                    {%- if linked_list != blank -%}
                      <ul class="linked-colors__list">
                        {%- comment -%} Current product first thumbnail {%- endcomment -%}
                        <li class="linked-colors__item">
                          <a class="linked-colors__thumb is-active" href="{{ product.url }}" aria-current="true" title="{{ product.title | escape }}">
                            {%- if product.featured_image != blank -%}
                              <img src="{{ product.featured_image | image_url: width: 240 }}" alt="{{ product.title | escape }}" loading="lazy" width="{{ lc_thumb_size }}" height="{{ lc_thumb_size }}">
                            {%- else -%}
                              <span class="linked-colors__thumb-placeholder"></span>
                            {%- endif -%}
                          </a>
                        </li>
                        {%- for linked in linked_list -%}
                          {%- if linked != blank and linked.id != product.id -%}
                            <li class="linked-colors__item">
                              <a class="linked-colors__thumb" href="{{ linked.url }}" title="{{ linked.title | escape }}">
                                {%- if linked.featured_image != blank -%}
                                  <img src="{{ linked.featured_image | image_url: width: 240 }}" alt="{{ linked.title | escape }}" loading="lazy" width="{{ lc_thumb_size }}" height="{{ lc_thumb_size }}">
                                {%- else -%}
                                  <span class="linked-colors__thumb-placeholder"></span>
                                {%- endif -%}
                              </a>
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- else -%}
                      {%- if request.design_mode -%}
                        <div class="linked-colors__empty" style="font-family:'Helvetica Neue',Arial,sans-serif;font-size:12px;color:#b85b3a;margin:0;line-height:1.55;background:#fff7ed;border:1px solid #f59e0b;padding:12px 14px;border-radius:4px;max-width:520px;">
                          <p style="margin:0 0 6px;font-weight:600;">⚠ Aucun produit lié trouvé</p>
                          <p style="margin:0 0 8px;">Vérifiez le metafield dans Admin Shopify → ce produit → Metafields.</p>
                          <p style="margin:0 0 4px;"><strong>Clés disponibles sur ce produit dans le namespace <code>custom</code> :</strong></p>
                          <ul style="margin:0;padding-left:18px;font-family:monospace;font-size:11px;color:#444;">
                            {%- for mf in product.metafields.custom -%}
                              {%- assign mf_handle = mf | first -%}
                              {%- assign mf_value = mf | last -%}
                              <li>
                                <strong>custom.{{ mf_handle }}</strong>
                                {%- if mf_value != blank and mf_value.value != blank -%}
                                  &nbsp;— rempli ({% if mf_value.value.size %}{{ mf_value.value.size }} élément(s){% else %}valeur présente{% endif %})
                                {%- else -%}
                                  &nbsp;— <em>vide</em>
                                {%- endif -%}
                              </li>
                            {%- else -%}
                              <li><em>(aucun metafield trouvé)</em></li>
                            {%- endfor -%}
                          </ul>
                          <p style="margin:8px 0 0;">→ Copie la clé correcte (ex: <code>linked_colors</code> ou <code>custom_linked_colors</code>) et colle-la dans le champ <strong>« Clé du metafield (avancé) »</strong> du bloc.</p>
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                </div>

            {%- when 'bundle_selector' -%}
              {%- liquid
                assign bs_target_product = block.settings.product
                if bs_target_product == blank
                  assign bs_target_product = product
                endif
                assign show_block = false
                if request.design_mode
                  assign show_block = true
                elsif block.settings.product == blank or product.handle == block.settings.product.handle
                  assign show_block = true
                endif
              -%}
              {%- if show_block -%}
                <div class="bundle-block-wrapper" {{ block.shopify_attributes }}>
                  {%- render 'bundle-selector-block',
                    block: block,
                    target_product: bs_target_product
                  -%}
                </div>
              {%- endif -%}
            
            {%- when 'title' -%}
              {%- liquid
                assign price_block = section.blocks | where: "type", "price" | first
                assign rating_block = section.blocks | where: "type", "rating" | first
              -%}
              <div class="product__title grid gap-3{% if price_block == blank and block.settings.show_price %} with-price{% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %} with-price--on-sale{% endif %}{% endif %}" {{ block.shopify_attributes }}>
                <{{ block.settings.title_tag }} class="heading leading-none {{ block.settings.title_size }} mobile:{{ block.settings.title_size_mobile }} col-span-full">
                  {%- if settings.enable_heading_reveal -%}
                    <split-words class="split-words js-invisible block" data-animate="fade-up">{{ product.title }}</split-words>
                  {%- else -%}
                    {{- product.title -}}
                  {%- endif -%}
                </{{ block.settings.title_tag }}>

                {%- if price_block == blank and block.settings.show_price -%}
                  <div id="Price-{{ section.id }}-{{ product.id }}" class="product__price">
                    {%- render 'product-price', product: product, use_variant: true, class: 'flex flex-wrap items-baseline gap-2 lg:flex-col xl:items-end lg:gap-1d5' -%}
                    
                    {%- if product.quantity_price_breaks_configured? -%}
                      <div class="text-opacity text-sm font-medium leading-tight" id="VolumeNote-{{ section.id }}-{{ product.id }}">
                        {{- 'products.volume_pricing.note' | t -}}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- liquid
                  if rating_block == blank and block.settings.show_rating
                    render 'product-rating', product: product
                  endif
                -%}
              </div>

              {%- if price_block == blank and block.settings.show_price -%}
                {%- assign product_form_installment_id = 'ProductFormInstallment-' | append: section.id | append: '-' | append: product.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment text-sm leading-tight' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
                  {{ form | payment_terms }}
                {%- endform -%}
              {%- endif -%}

            {%- when 'price' -%}
              <div class="product__price grid gap-3" {{ block.shopify_attributes }}>
                <div class="no-js-hidden" id="Price-{{ section.id }}-{{ product.id }}">
                  {%- render 'product-price', product: product, use_variant: true, class: 'flex flex-wrap items-baseline gap-2 lg:gap-1d5' -%}
                  
                  {%- if product.quantity_price_breaks_configured? -%}
                    <div class="text-opacity text-sm font-medium leading-tight" id="VolumeNote-{{ section.id }}-{{ product.id }}">
                      {{- 'products.volume_pricing.note' | t -}}
                    </div>
                  {%- endif -%}
                </div>

                {%- assign product_form_installment_id = 'ProductFormInstallment-' | append: section.id | append: '-' | append: product.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment text-sm leading-tight' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
                  {{ form | payment_terms }}
                {%- endform -%}

                {%- if block.settings.show_taxes_notice -%}
                  {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                    <div class="product__tax rte text-sm">
                      {%- liquid
                        if cart.taxes_included
                          echo 'products.product.include_taxes' | t
                        endif
                        if shop.shipping_policy.body != blank
                          echo 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url
                        endif
                      -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>

            {%- when 'quantity_selector' -%}
              {%- if product.available -%}
                <div id="QuantityForm-{{ section.id }}-{{ product.id }}" class="field" {{ block.shopify_attributes }}>
                  {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}
                  <label for="Quantity-{{ section.id }}-{{ product.id }}" class="quantity__label label" is="quantity-label">
                    {{ 'products.quantity.label' | t }}
                    <span id="QuantityRulesCart-{{ section.id }}-{{ product.id }}" class="quantity__rules-cart{% if cart_qty == 0 %} hidden{% endif %} relative">
                      <span class="quantity-cart font-medium">({{ 'products.quantity.in_cart_html' | t: quantity: cart_qty }})</span>
                    </span>
                  </label>
                  <div class="flex items-center gap-4">
                    <quantity-input class="quantity inline-flex relative" data-section-id="{{ section.id }}" data-product-id="{{ product.id }}">
                      <button type="button" name="minus" class="quantity__button" aria-label="{{ 'products.quantity.decrease' | t: product: product.title | escape }}">
                        {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                      <input
                        id="Quantity-{{ section.id }}-{{ product.id }}"
                        class="quantity__input text-sm sm:text-base font-medium text-center"
                        type="number"
                        name="quantity"
                        inputmode="numeric"
                        autocomplete="off"
                        data-quantity-variant-id="{{ product.selected_or_first_available_variant.id }}"
                        data-cart-quantity="{{ cart_qty }}"
                        data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                          data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                          max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                        {% endif %}
                        step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                        value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        form="{{ product_form_id }}"
                      />
                      <button type="button" name="plus" class="quantity__button" aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}">
                        {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                    </quantity-input>

                    {%- if product.quantity_price_breaks_configured? -%}
                      {%- liquid
                        assign volume_pricing_array = product.selected_or_first_available_variant.quantity_price_breaks | sort: 'quantity' | reverse
                        assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.min
                        if cart_qty > 0
                          assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.increment
                        endif
                        assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price
                      -%}
                      <price-per-item
                        id="PricePerItem-{{ section.id }}-{{ product.id }}"
                        class="price flex flex-wrap items-center gap-2 lg:gap-1d5"
                        data-section-id="{{ section.id }}"
                        data-product-id="{{ product.id }}"
                        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      >
                        {%- if variant_price_compare -%}
                          <span class="sr-only">{{ 'products.price.regular_price' | t }}</span>
                          <span class="price__sale inline-flex items-center h-auto relative">
                            {%- liquid
                              if settings.currency_code_enabled
                                echo variant_price_compare | money_with_currency
                              else
                                echo variant_price_compare | money
                              endif
                            -%}
                          </span>
                          <span class="sr-only">{{ 'products.price.sale_price' | t }}</span>
                        {%- endif -%}
                        
                        {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                          {%- if current_qty_for_volume_pricing < volume_pricing_array.last.minimum_quantity -%}
                            {%- liquid
                              if settings.currency_code_enabled
                                assign variant_price = product.selected_or_first_available_variant.price | money_with_currency
                              else
                                assign variant_price = product.selected_or_first_available_variant.price | money
                              endif
                            -%}
                            <span class="price-per-item--current price__regular whitespace-nowrap">
                              {{- 'products.volume_pricing.price_at_each' | t: price: variant_price -}}
                            </span>
                          {%- else -%}
                            {%- for price_break in volume_pricing_array -%}
                              {%- if current_qty_for_volume_pricing >= price_break.minimum_quantity -%}
                                {%- liquid
                                  if settings.currency_code_enabled
                                    assign price_break_price = price_break.price | money_with_currency
                                  else
                                    assign price_break_price = price_break.price | money
                                  endif
                                -%}
                                <span class="price-per-item--current price__regular whitespace-nowrap">
                                  {{- 'products.volume_pricing.price_at_each' | t: price: price_break_price -}}
                                </span>
                                {%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- else -%}
                          <span class="price-per-item--current price__regular whitespace-nowrap">
                            {%- liquid
                              if settings.currency_code_enabled
                                assign variant_price = product.selected_or_first_available_variant.price | money_with_currency
                              else
                                assign variant_price = product.selected_or_first_available_variant.price | money
                              endif
                            -%}
                            {{- 'products.volume_pricing.price_at_each' | t: price: variant_price -}}
                          </span>
                        {%- endif -%}
                      </price-per-item>
                    {%- endif -%}
                  </div>

                  {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 or product.selected_or_first_available_variant.quantity_rule.min > 1 or product.selected_or_first_available_variant.quantity_rule.max != null -%}
                    <div class="quantity__rules text-sm font-medium leading-tight" id="QuantityRules-{{ section.id }}-{{ product.id }}">
                      {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                        <span class="divider">
                          {{- 'products.quantity.multiples_of' | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment -}}
                        </span>
                      {%- endif -%}
                      {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                        <span class="divider">
                          {{- 'products.quantity.minimum_of' | t: quantity: product.selected_or_first_available_variant.quantity_rule.min -}}
                        </span>
                      {%- endif -%}
                      {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                        <span class="divider">
                          {{- 'products.quantity.maximum_of' | t: quantity: product.selected_or_first_available_variant.quantity_rule.max -}}
                        </span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'volume_pricing' -%}
              {%- if product.quantity_price_breaks_configured? -%}
                <volume-pricing class="volume-pricing grid gap-6" id="Volume-{{ section.id }}-{{ product.id }}">
                  {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                    <span class="caption-large font-medium">{{ 'products.volume_pricing.title' | t }}</span>
                    <ul class="list-unstyled">
                      <li class="text-sm flex gap-2d5 justify-between">
                        <span class="font-medium">{{ product.selected_or_first_available_variant.quantity_rule.min }}+</span>
                        {%- liquid
                          if settings.currency_code_enabled
                            assign variant_price = product.selected_or_first_available_variant.price | money_with_currency
                          else
                            assign variant_price = product.selected_or_first_available_variant.price | money
                          endif
                        -%}
                        <span data-text="{{ 'products.volume_pricing.price_at_each' | t: price: variant_price }}">
                          {{- 'sections.quick_order_list.each' | t: money: variant_price -}}
                        </span>
                      </li>
                      {%- for price_break in product.selected_or_first_available_variant.quantity_price_breaks -%}
                        {%- liquid
                          if settings.currency_code_enabled
                            assign price_break_price = price_break.price | money_with_currency
                          else
                            assign price_break_price = price_break.price | money
                          endif
                        -%}
                        <li class="text-sm flex gap-2d5 justify-between{% if forloop.index >= 3 %} show-more-item hidden{% endif %}">
                          <span class="font-medium">
                            {{- price_break.minimum_quantity -}}
                            <span aria-hidden="true">+</span>
                          </span>
                          <span data-text="{{ 'products.volume_pricing.price_at_each' | t: price: price_break_price }}">
                            {{- 'sections.quick_order_list.each' | t: money: price_break_price -}}
                          </span>
                        </li>
                      {%- endfor -%}
                    </ul>
                    {%- if product.selected_or_first_available_variant.quantity_price_breaks.size >= 3 -%}
                      <show-more-button>
                        <button
                          class="button-show-more link text-sm leading-tight"
                          id="ShowMore-{{ section.id }}-{{ product.id }}"
                          type="button"
                        >
                          <span class="label-show-more">{{ 'products.general.show_more' | t }}</span>
                        </button>
                      </show-more-button>
                    {%- endif -%}
                  {%- endif -%}
                </volume-pricing>
              {%- endif -%}

            {%- when 'variant_picker' -%}
              {%- render 'product-variant-picker',
                block: block,
                product: product,
                product_id: product.id,
                section_id: section.id,
                product_form_id: product_form_id,
                image_ratio: section.settings.image_ratio,
                image_ratio_mobile: section.settings.image_ratio_mobile,
                image_fill: settings.product_image_fill
              -%}
              
            {%- when 'product_variations' -%}
              {%- render 'product-variants',
                block: block,
                product: product,
                product_id: product.id,
                section_id: section.id,
                image_ratio: section.settings.image_ratio,
                image_ratio_mobile: section.settings.image_ratio_mobile,
                image_fill: settings.product_image_fill
              -%}

            {%- when 'buy_buttons' -%}
              {%- render 'buy-buttons',
                block: block,
                section: section,
                product: product,
                product_id: product.id,
                section_id: section.id,
                product_form_id: product_form_id
              -%}

            {%- when 'pickup_availability' -%}
              {%- render 'pickup-availability',
                block: block,
                section: section,
                product: product,
                product_id: product.id,
                section_id: section.id,
                product_form_id: product_form_id
              -%}

            {%- when 'inventory' -%}
              {%- render 'product-inventory',
                block: block,
                product: product,
                product_id: product.id,
                section_id: section.id
              -%}

            {%- when 'share' -%}
              <div class="flex justify-between items-center" {{ block.shopify_attributes }}>
                {%- liquid
                  assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
                  assign share_image = product.selected_variant.featured_image | default: product.featured_image
                -%}
                {%- render 'social-sharing',
                  section_id: section.id,
                  share_id: product.id,
                  share_label: block.settings.share_label,
                  share_title: product.title,
                  share_link: share_url,
                  share_image: share_image
                -%}

                {%- if block.settings.show_help_desk -%}
                  <div class="flex items-center gap-2">
                    {%- render 'icon', icon: 'question' -%}
                    {%- if block.settings.help_type == 'drawer' -%}
                      <button type="button" class="link text-sm leading-tight cursor-pointer" aria-controls="HelpDrawer">
                        {{- block.settings.help_label | escape -}}
                      </button>
                    {%- else -%}
                      <a class="link text-sm leading-tight cursor-pointer"{% if block.settings.help_page != blank %} href="{{ block.settings.help_page.url }}"{% if block.settings.help_page_external %} target="_blank" rel="noopener noreferrer"{% endif %}{% else %} role="link" aria-disabled="true"{% endif %}>
                        {{- block.settings.help_label | escape -}}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'help_desk' -%}
              <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
                {%- render 'icon', icon: 'question' -%}
                {%- if block.settings.help_type == 'drawer' -%}
                  <button type="button" class="link text-sm leading-tight cursor-pointer" aria-controls="HelpDrawer">
                    {{- block.settings.help_label | escape -}}
                  </button>
                {%- else -%}
                  <a class="link text-sm leading-tight cursor-pointer"{% if block.settings.help_page != blank %} href="{{ block.settings.help_page.url }}"{% if block.settings.help_page_external %} target="_blank" rel="noopener noreferrer"{% endif %}{% else %} role="link" aria-disabled="true"{% endif %}>
                    {{- block.settings.help_label | escape -}}
                  </a>
                {%- endif -%}
              </div>

            {%- when 'rating' -%}
              {%- render 'product-rating', product: product, block: block -%}

            {%- when 'complementary' -%}
              {%- render 'product-complementary',
                section_id: section.id,
                product_id: product.id,
                image_ratio: settings.product_image_ratio,
                image_fill: settings.product_image_fill,
                limit: block.settings.product_limit,
                heading: block.settings.heading,
                show_vendor: block.settings.show_vendor,
                show_price: block.settings.show_price,
              -%}

            {%- when 'liquid' -%}
              {%- if block.settings.liquid != blank -%}
                <div class="rte" {{ block.shopify_attributes }}>
                  {{- block.settings.liquid -}}
                </div>
              {%- endif -%}

            {%- when 'collapsible_tab' -%}
              <details class="product__accordion details {{ block.settings.style }}" is="accordion-details"{% if block.settings.opened %} open{% endif %} {{ block.shopify_attributes }}>
                <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
                  <div class="flex items-center gap-2d5">
                    {%- render 'icon-accordion', icon: block.settings.icon -%}
                    <span class="text-sm-base font-medium leading-none">{{ block.settings.heading | default: block.settings.page.title | escape }}</span>
                  </div>
                  {%- render 'icon', icon: 'plus-2', size: 'xs', class: 'shrink-0' -%}
                </summary>
                <div class="details__content rte {{ block.settings.text_size }} text-opacity">
                  {{ block.settings.content }}
                  {{ block.settings.page.content }}
                  {{ block.settings.liquid }}
                </div>
              </details>

            {%- when 'countdown' -%}
              {%- if product.metafields.theme.countdown.value != blank -%}
                {%- liquid
                  assign now_time = 'now' | date: '%s' | times: 1
                  assign countdown_time = product.metafields.theme.countdown.value | date: '%s' | times: 1
                -%}
                {%- if countdown_time > now_time -%}
                  <div class="product-countdown grid sm:flex items-center justify-between gap-2d5" id="shopify-block-{{ block.id }}" {{ block.shopify_attributes }}>
                    <div class="flex items-center gap-3">
                      {%- render 'icon', icon: 'countdown', size: 'xl', class: 'shrink-0 block lg:hidden xl:block' -%}
                      <div class="grid">
                        {%- if block.settings.heading != blank -%}
                          <p class="heading text-base lg:text-lg xl:text-xl leading-tight">{{ block.settings.heading | escape }}</p>
                        {%- endif -%}
                        {%- if block.settings.subheading != blank -%}
                          <p class="uppercase text-3xs font-medium leading-none tracking-widest">{{ block.settings.subheading | escape }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                    <countdown-timer
                      class="countdown__timer flex text-center"
                      data-expires="{{ product.metafields.theme.countdown.value | date: '%FT%T%:z' | escape }}"
                    >
                      <div class="countdown__item">
                        <p>--</p><span>{{ 'general.date.days' | t }}</span>
                      </div>
                      <div class="countdown__item">
                        <p>--</p><span>{{ 'general.date.hours' | t }}</span>
                      </div>
                      <div class="countdown__item">
                        <p>--</p><span>{{ 'general.date.minutes' | t }}</span>
                      </div>
                      <div class="countdown__item">
                        <p>--</p><span>{{ 'general.date.seconds' | t }}</span>
                      </div>
                    </countdown-timer>
                    <style>
                      #shopify-block-{{ block.id }} {
                        {%- render 'section-variables', section: block -%}
                      }
                    </style>
                  </div>
                {%- endif -%}
              {%- endif -%}

            {%- when 'back_in_stock' -%}
              <div id="BackInStock-{{ section.id }}-{{ product.id }}" class="back-in-stock" {{ block.shopify_attributes }}>
                {%- liquid
                  assign check_against_inventory = true
                  if product.selected_or_first_available_variant.inventory_management != 'shopify' or  product.selected_or_first_available_variant.inventory_policy == 'continue'
                    assign check_against_inventory = false
                  endif
                  if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
                    assign quantity_rule_soldout = true
                  endif

                  if product.selected_or_first_available_variant.available == false or quantity_rule_soldout
                    render 'back-in-stock', product: product, product_id: product.id, section_id: section.id, heading: block.settings.heading, description: block.settings.description, compact: true
                  endif
                -%}
              </div>

            {%- when 'product_bundle' -%}
              {%- liquid
                assign products = block.settings.products
                
                if block.settings.metafield != blank
                  assign metafield_parts = block.settings.metafield | split: '.'
                  assign metafield_namespace = metafield_parts | first
                  assign metafield_key = metafield_parts | last
                  
                  assign metafield = product.metafields[metafield_namespace][metafield_key]
                  if metafield.value != blank and metafield.list?
                    assign products = metafield.value
                  endif

                  assign metafield = product.selected_or_first_available_variant.metafields[metafield_namespace][metafield_key]
                  if metafield.value != blank and metafield.list?
                    assign products = metafield.value
                  endif
                endif
              -%}
              <div id="ProductBundle-{{ section.id }}-{{ product.id }}" {{ block.shopify_attributes }}>
                {%- if products.count > 0 -%}
                  <details class="product__accordion details with-background" is="product-bundle-details"{% if product.selected_or_first_available_variant.available and block.settings.opened %} open{% endif %} form="{{ product_form_id }}">
                    <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
                      <div class="flex items-center gap-2d5">
                        {%- if block.settings.icon_image != blank -%}
                          {%- liquid
                            if block.settings.iwidth == 'fit'
                              assign icon_width = block.settings.icon_image.width
                            else
                              assign icon_width = block.settings.icon_width
                            endif
                            assign image_alt = block.settings.icon_image.alt | default: block.settings.accessibility_info | escape
                            assign image_alt = image_alt | default: block.settings.heading | escape
                            assign max_width = block.settings.icon_image.width
                          -%}
                          <figure class="media media--transparent relative inline-block">
                            {%- capture sizes -%}{{ icon_width }}px{%- endcapture -%}
                            {%- capture widths -%}{{ icon_width | times: 1.5 | at_most: max_width | round }}, {{ icon_width | times: 2 | at_most: max_width }}, {{ icon_width | times: 3 | at_most: max_width }}{%- endcapture -%}
                            {{- block.settings.icon_image | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: image_alt, class: 'image-fit' -}}
                          </figure>
                        {%- elsif block.settings.icon != 'none' -%}
                          {%- liquid
                            if block.settings.iwidth == 'fit'
                              render 'icon-guarantee', icon: block.settings.icon, size: 'lg', class: 'inline-block stroke-1'
                            else
                              render 'icon-guarantee', icon: block.settings.icon, size: 'custom', class: 'inline-block stroke-1', width: block.settings.icon_width
                            endif
                          -%}
                        {%- endif -%}
                        <span class="text-sm-base font-medium leading-none">{{ block.settings.heading | escape }}</span>
                      </div>
                      {%- render 'icon', icon: 'plus-2', size: 'xs', class: 'shrink-0' -%}
                    </summary>
                    <div class="details__content grid gap-2">
                      {%- for product in products -%}
                        {%- liquid
                          assign variant = product.first_available_variant | default: product
                          assign show_variant_title = true

                          if variant.product.has_only_default_variant
                            assign show_variant_title = false
                          endif

                          if product.first_available_variant == nil
                            assign show_variant_title = false
                          endif
                        -%}
                        {%- if variant.product -%}
                          {%- assign variant_image = variant.image | default: variant.product.featured_image -%}
                          <label class="product-bundle__info{% if variant_image %} with-image{% endif %} flex items-center gap-4 md:gap-6 relative" for="Recommendations-{{ section.id }}-{{ variant.id }}"{% if block.settings.variant_selection %} is="product-bundle-picker"{% endif %}>
                            <input name="bundles" value="{{ variant.id }}" data-price="{{ variant.price }}" class="checkbox" id="Recommendations-{{ section.id }}-{{ variant.id }}" type="checkbox"{% unless variant.available %} disabled{% endunless %} />
                            {%- if variant_image -%}
                              <picture class="horizontal-product__media media media--{{ settings.product_image_ratio }}{% unless settings.product_image_fill %} media--contain{% endunless %} relative overflow-hidden shrink-0 pointer-events-none">
                                {%- assign max_width = variant_image.width -%}
                                {%- capture sizes -%}64px{%- endcapture -%}
                                {%- capture widths -%}{{ 64 | times: 1.5 | at_most: max_width | round }}, {{ 64 | times: 2 | at_most: max_width }}, {{ 64 | times: 3 | at_most: max_width }}{%- endcapture -%}
                                {{- variant_image | image_url: width: variant_image.width | image_tag: loading: 'lazy', widths: widths, sizes: sizes, is: 'lazy-image' -}}
                              </picture>
                            {%- endif -%}
                            <div class="horizontal-product__details grow flex flex-col justify-start gap-1d5">
                              <div class="flex flex-col gap-1">
                                <p class="horizontal-product__title font-medium text-base leading-tight">
                                  {%- liquid
                                    if block.settings.clickable
                                      echo variant.product.title | link_to: variant.url, class: 'reversed-link'
                                    else
                                      echo variant.product.title | escape
                                    endif
                                  -%}
                                </p>
                                {%- if show_variant_title -%}
                                  {%- if block.settings.variant_selection -%}
                                    <div>
                                      <div class="field inline-block">
                                        <select class="select" id="Variants-{{ section.id }}-{{ block.id }}-{{ product.id }}">
                                          {%- for product_variant in variant.product.variants -%}
                                            {%- assign product_variant_image = product_variant.image | default: product_variant.product.featured_image -%}
                                            <option
                                              {% if product_variant == variant.product.selected_or_first_available_variant %}selected{% endif %}
                                              {% if product_variant.available == false %}disabled{% endif %}
                                              value="{{ product_variant.id }}"
                                              data-price="{{ product_variant.price }}"
                                              data-img-src="{{ product_variant_image | image_url: width: 540 }}"
                                              data-img-srcset="{{ product_variant_image | image_url: width: '180x' }} 180w, {{ product_variant_image | image_url: width: '360x' }} 360w, {{ product_variant_image | image_url: width: '540x' }} 540w"
                                            >
                                              {{ product_variant.title }}
                                              {%- if product_variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
                                            </option>
                                          {%- endfor -%}
                                        </select>
                                        {%- render 'icon', icon: 'chevron-up', size: 'xs', class: 'absolute pointer-events-none' -%}
                                      </div>
                                    </div>
                                  {%- else -%}
                                    <span class="text-xs text-opacity leading-tight">{{ variant.title }}</span>
                                  {%- endif -%}
                                {%- endif -%}
                              </div>
                            </div>
                            <div class="horizontal-product__quantity shrink-0">
                              {%- if variant.available -%}
                                {%- render 'product-price', product: variant.product, variant: variant, use_variant: true, hide_sale_price: block.settings.variant_selection, class: 'flex flex-wrap items-baseline gap-2 lg:flex-col xl:items-end lg:gap-1d5' -%}
                              {%- else -%}
                                <span class="text-sm-base text-opacity">{{ 'products.product.sold_out' | t }}</span>
                              {%- endif -%}
                            </div>
                          </label>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </details>
                {%- endif -%}
              </div>

            {%- when 'icon_list' -%}
              {{- icon_list_render -}}

            {%- when 'line_item_property' -%}
              {%- assign custom_name = block.settings.title | escape -%}
              <div class="field" {{ block.shopify_attributes }}>
                {%- if block.settings.type == 'checkbox' -%}
                  <label for="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}" class="flex items-center gap-3">
                    <input
                      type="hidden"
                      name="properties[{{ custom_name }}]"
                      form="{{ product_form_id }}"
                      value="{{ block.settings.unchecked_value | escape }}"
                    />
                    <input
                      type="checkbox"
                      id="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}"
                      name="properties[{{ custom_name }}]"
                      form="{{ product_form_id }}"
                      value="{{ block.settings.checked_value | escape }}"
                      {%- if block.settings.required %} required{% endif -%}
                    />
                    {{- block.settings.title | escape -}}
                  </label>

                  {%- elsif block.settings.type == 'radio' -%}
                  <div class="grid gap-4">
                    <p>{{ block.settings.title | escape }}</p>
                    {%- assign options = block.settings.radio_options | split: ',' -%}
                    {%- if options.size > 0 -%}
                      <ul class="grid gap-2 leading-none" role="list">
                        {%- for option in options -%}
                          {%- assign option_2 = option | strip | escape -%}
                          <li>
                            <label for="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}-{{ forloop.index0 }}" class="inline-flex items-center gap-3">
                              <input
                                type="radio"
                                id="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}-{{ forloop.index0 }}"
                                name="properties[{{ custom_name }}]"
                                form="{{ product_form_id }}"
                                value="{{ option_2 }}"
                                {%- if block.settings.required %} required{% endif -%}
                              />
                              {{- option_2 -}}
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
  
                {%- else -%}
                  {%- case block.settings.type -%}
                    {%- when 'text' -%}
                      <input
                        class="input is-floating"
                        type="text"
                        id="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}"
                        name="properties[{{ custom_name }}]"
                        form="{{ product_form_id }}"
                        placeholder="{{ block.settings.title | escape }}"
                        {%- if block.settings.required %} required{% endif -%}
                      />
                      <label class="label is-floating" for="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}">{{ block.settings.title | escape }}</label>
  
                    {%- when 'textarea' -%}
                      <textarea
                        class="textarea is-floating"
                        rows="5"
                        id="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}"
                        name="properties[{{ custom_name }}]"
                        form="{{ product_form_id }}"
                        placeholder=" "
                        {%- if block.settings.required %} required{% endif -%}
                      ></textarea>
                      <label class="label is-floating" for="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}">{{ block.settings.title | escape }}</label>
  
                    {%- when 'select' -%}
                      {%- assign options = block.settings.select_options | split: ',' -%}
                      {%- if options.size > 0 -%}
                        <select
                          class="select is-floating"
                          id="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}"
                          name="properties[{{ custom_name }}]"
                          form="{{ product_form_id }}"
                          {%- if block.settings.required %} required{% else %} is="custom-select"{% endif -%}
                        >
                          <option value="" disabled selected></option>
                          {%- for option in options -%}
                            {%- assign option_2 = option | strip | escape -%}
                            <option value="{{ option_2 }}">{{ option_2 }}</option>
                          {%- endfor -%}
                        </select>
                        {%- render 'icon', icon: 'chevron-up', size: 'sm', class: 'absolute pointer-events-none' -%}
                      {%- endif -%}
                      <label class="label{% if options.size > 0 %} is-floating{% endif %}" for="LineItemInput-{{ section.id }}-{{ product.id }}-{{ block.id }}">{{ block.settings.title | escape }}</label>
                  {%- endcase -%}
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </product-info>
    </div>

    {%- assign sticky_buy_button = section.blocks | where: "type", "sticky_buy_button" | first -%}
    {%- if product.available and sticky_buy_button -%}
      <product-sticky-form
        class="product-sticky-form w-full fixed z-20 bottom-0 right-0 pointer-events-none"
        id="ProductStickyForm-{{ section.id }}-{{ product.id }}"
        form="{{ product_form_id }}"
      >
        <div class="product-sticky-form__card grid gap-4 opacity-0 invisible pointer-events-auto">
          {%- assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
          <div class="product-sticky-form__variant{% if featured_media == blank %} no-image{% endif %} grid items-center gap-4">
            {%- if featured_media != blank -%}
              {%- assign max_width = featured_media.width -%}
              {%- capture sizes -%}80px{%- endcapture -%}
              {%- capture widths -%}{{ 80 | times: 1.5 | at_most: max_width | round }}, {{ 80 | times: 2 | at_most: max_width }}, {{ 80 | times: 3 | at_most: max_width }}{%- endcapture -%}
              <div class="hidden md:block media media--adapt relative overflow-hidden" data-widths="{{ widths }}" data-sticky-product-media>
                {{- featured_media | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, is: 'lazy-image' -}}
              </div>
            {%- endif -%}

            <div class="grid gap-2">
              <div class="grid gap-1">
                <p class="text-base font-medium leading-tight">{{ product.title }}</p>
                {%- unless product.has_only_default_variant -%}
                  <div class="text-xs text-opacity leading-tight" data-sticky-product-options>
                    {{- product.selected_or_first_available_variant.title -}}
                  </div>
                {%- endunless -%}
              </div>
              <div id="StickyPrice-{{ section.id }}-{{ product.id }}">
                {%- if product.quantity_price_breaks_configured? != true -%}
                  {%- render 'product-price', product: product, use_variant: true, class: 'flex flex-wrap items-center gap-2 lg:gap-1d5' -%}
                {%- else -%}
                  {%- liquid
                    assign assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id
                    assign volume_pricing_array = product.selected_or_first_available_variant.quantity_price_breaks | sort: 'quantity' | reverse
                    assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.min
                    if cart_qty > 0
                      assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.increment
                    endif
                    assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price
                  -%}
                  <price-per-item
                    id="PricePerItem-{{ section.id }}-{{ product.id }}-2nd"
                    class="price flex flex-wrap items-center gap-2 lg:gap-1d5"
                    data-section-id="{{ section.id }}"
                    data-product-id="{{ product.id }}"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  >
                    {%- if variant_price_compare -%}
                      <span class="sr-only">{{ 'products.price.regular_price' | t }}</span>
                      <span class="price__sale inline-flex items-center h-auto relative">
                        {%- liquid
                          if settings.currency_code_enabled
                            echo variant_price_compare | money_with_currency
                          else
                            echo variant_price_compare | money
                          endif
                        -%}
                      </span>
                      <span class="sr-only">{{ 'products.price.sale_price' | t }}</span>
                    {%- endif -%}
                    
                    {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                      {%- if current_qty_for_volume_pricing < volume_pricing_array.last.minimum_quantity -%}
                        {%- liquid
                          if settings.currency_code_enabled
                            assign variant_price = product.selected_or_first_available_variant.price | money_with_currency
                          else
                            assign variant_price = product.selected_or_first_available_variant.price | money
                          endif
                        -%}
                        <span class="price-per-item--current price__regular whitespace-nowrap">
                          {{- 'products.volume_pricing.price_at_each' | t: price: variant_price -}}
                        </span>
                      {%- else -%}
                        {%- for price_break in volume_pricing_array -%}
                          {%- if current_qty_for_volume_pricing >= price_break.minimum_quantity -%}
                            {%- liquid
                              if settings.currency_code_enabled
                                assign price_break_price = price_break.price | money_with_currency
                              else
                                assign price_break_price = price_break.price | money
                              endif
                            -%}
                            <span class="price-per-item--current price__regular whitespace-nowrap">
                              {{- 'products.volume_pricing.price_at_each' | t: price: price_break_price -}}
                            </span>
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                    {%- else -%}
                      <span class="price-per-item--current price__regular whitespace-nowrap">
                        {%- liquid
                          if settings.currency_code_enabled
                            assign variant_price = product.selected_or_first_available_variant.price | money_with_currency
                          else
                            assign variant_price = product.selected_or_first_available_variant.price | money
                          endif
                        -%}
                        {{- 'products.volume_pricing.price_at_each' | t: price: variant_price -}}
                      </span>
                    {%- endif -%}
                  </price-per-item>
                {%- endif -%}
              </div>
            </div>

            {%- liquid
              assign check_against_inventory = true
              if product.selected_or_first_available_variant.inventory_management != 'shopify' or  product.selected_or_first_available_variant.inventory_policy == 'continue'
                assign check_against_inventory = false
              endif
              if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
                assign quantity_rule_soldout = true
              endif

              if product.selected_or_first_available_variant.available == false or quantity_rule_soldout
                assign add_to_cart_label = 'products.product.sold_out' | t
                assign add_to_cart_aria = 'products.product.sold_out' | t
              elsif product.template_suffix != 'pre-order'
                assign add_to_cart_label = 'products.product.add_to_cart' | t
                assign add_to_cart_aria = 'products.product.add_to_cart_label' | t: title: product.title
              else
                assign add_to_cart_label = 'products.product.pre_order' | t
                assign add_to_cart_aria = 'products.product.pre_order_label' | t: title: product.title
              endif
            -%}
            <button
              type="submit"
              name="add"
              form="{{ product_form_id }}"
              class="button button--primary"
              is="hover-button"
              aria-label="{{ add_to_cart_aria | escape }}"
              {%- if product.selected_or_first_available_variant.available == false or quantity_rule_soldout %} disabled{% endif -%}
              {%- if product.template_suffix == 'pre-order' %} data-pre-order{% endif -%}
            >
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                <span class="hidden md:block" data-sold-out="{{ 'products.product.sold_out' | t | escape }}">
                  {{- add_to_cart_label -}}
                </span>
              </span>
            </button>
          </div>
          <div class="product-form__error-message alert alert--error text-sm font-medium leading-tight" role="alert" hidden></div>
        </div>
      </product-sticky-form>
    {%- endif -%}
  </div>

  {%- if first_3d_model -%}
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>
  {%- endif -%}
  
  <script type="application/ld+json">
    {{- product | structured_data -}}
  </script>
</div>

{% schema %}
{
  "name": "t:sections.main-product.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "default": true,
      "label": "t:sections.main-product.settings.enable_sticky_info.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-product.settings.header__media.content",
      "info": "t:sections.main-product.settings.header__media.info"
    },
    {
      "type": "range",
      "id": "media_size",
      "min": 35,
      "max": 70,
      "step": 1,
      "unit": "%",
      "default": 66,
      "label": "t:sections.main-product.settings.media_size.label",
      "info": "t:sections.main-product.settings.media_size.info"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        {
          "value": "scroll",
          "label": "t:sections.main-product.settings.gallery_layout.options__1.label"
        },
        {
          "value": "columns",
          "label": "t:sections.main-product.settings.gallery_layout.options__2.label"
        },
        {
          "value": "thumbnail",
          "label": "t:sections.main-product.settings.gallery_layout.options__3.label"
        }
      ],
      "default": "thumbnail",
      "label": "t:sections.main-product.settings.gallery_layout.label"
    },
    {
      "visible_if": "{{ section.settings.gallery_layout == 'thumbnail' }}",
      "type": "select",
      "id": "thumbnail_position",
      "options": [
        {
          "value": "beside",
          "label": "t:sections.main-product.settings.thumbnail_position.options__1.label"
        },
        {
          "value": "below",
          "label": "t:sections.main-product.settings.thumbnail_position.options__2.label"
        }
      ],
      "default": "beside",
      "label": "t:sections.main-product.settings.thumbnail_position.label",
      "info": "t:sections.main-product.settings.thumbnail_position.info"
    },
    {
      "visible_if": "{{ section.settings.gallery_layout == 'thumbnail' }}",
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.global.settings.image_ratio.options__1.label"
        },
        {
          "value": "square",
          "label": "t:sections.global.settings.image_ratio.options__2.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.global.settings.image_ratio.options__3.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.global.settings.image_ratio.options__4.label"
        },
        {
          "value": "wide",
          "label": "t:sections.global.settings.image_ratio.options__5.label"
        },
        {
          "value": "adapt_first",
          "label": "t:sections.global.settings.image_ratio.options__7.label"
        }
      ],
      "default": "adapt_first",
      "label": "t:sections.global.settings.image_ratio.label",
      "info": "t:sections.main-product.settings.image_ratio.info"
    },
    {
      "type": "select",
      "id": "image_zoom",
      "options": [
        {
          "value": "lightbox",
          "label": "t:sections.main-product.settings.image_zoom.options__1.label"
        },
        {
          "value": "hover",
          "label": "t:sections.main-product.settings.image_zoom.options__2.label"
        },
        {
          "value": "none",
          "label": "t:sections.main-product.settings.image_zoom.options__3.label"
        }
      ],
      "default": "lightbox",
      "label": "t:sections.main-product.settings.image_zoom.label",
      "info": "t:sections.main-product.settings.image_zoom.info"
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
      "default": false,
      "label": "t:sections.main-product.settings.hide_variants.label"
    },
    {
      "type": "checkbox",
      "id": "enable_video_autoplay",
      "default": false,
      "label": "t:sections.main-product.settings.enable_video_autoplay.label",
      "info": "t:sections.main-product.settings.enable_video_autoplay.info"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": false,
      "label": "t:sections.main-product.settings.enable_video_looping.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__mobile.content"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        {
          "value": "partial",
          "label": "t:sections.main-product.settings.mobile_layout.options__1.label"
        },
        {
          "value": "full_width",
          "label": "t:sections.main-product.settings.mobile_layout.options__2.label"
        }
      ],
      "default": "partial",
      "label": "t:sections.main-product.settings.mobile_layout.label"
    },
    {
      "type": "select",
      "id": "image_ratio_mobile",
      "options": [
        {
          "value": "adapt",
