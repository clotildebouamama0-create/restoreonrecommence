{%- liquid
  assign bg = section.settings.bg_color | default: '#f4efe5'
  assign text_color = section.settings.text_color | default: '#1a1a1a'
  assign muted_color = section.settings.muted_color | default: '#6a6a6a'
  assign cta_color = section.settings.cta_color | default: text_color
  assign check_color = section.settings.check_color | default: text_color
  assign image_position = section.settings.image_position | default: 'left'
  assign height_d = section.settings.height_desktop | default: 600
  assign height_m = section.settings.height_mobile | default: 420

  assign eyebrow_font = section.settings.eyebrow_font | default: 'sans'
  assign title_font = section.settings.title_font | default: 'serif'
  assign desc_font = section.settings.desc_font | default: 'sans'
  assign check_font = section.settings.check_font | default: 'sans'

  assign eyebrow_size = section.settings.eyebrow_size | default: 13
  assign title_size = section.settings.title_size | default: 48
  assign desc_size = section.settings.desc_size | default: 15
  assign check_size = section.settings.check_size | default: 14

  assign eyebrow = section.settings.eyebrow
  assign title = section.settings.title
  assign description = section.settings.description
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign cta_underline = section.settings.cta_underline
  assign checks = section.blocks | where: 'type', 'check'
-%}

{%- capture font_eyebrow -%}{% case eyebrow_font %}{% when 'mono' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'mono-light' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'serif' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% when 'serif-italic' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% else %}'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif{% endcase %}{%- endcapture -%}
{%- capture font_title -%}{% case title_font %}{% when 'mono' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'mono-light' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'serif' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% when 'serif-italic' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% else %}'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif{% endcase %}{%- endcapture -%}
{%- capture font_desc -%}{% case desc_font %}{% when 'mono' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'mono-light' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'serif' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% when 'serif-italic' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% else %}'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif{% endcase %}{%- endcapture -%}
{%- capture font_check -%}{% case check_font %}{% when 'mono' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'mono-light' %}'Founders Grotesk Mono', ui-monospace, monospace{% when 'serif' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% when 'serif-italic' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% else %}'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif{% endcase %}{%- endcapture -%}

<style>
  #shopify-section-{{ section.id }} { background: {{ bg }}; }
  #shopify-section-{{ section.id }} .stc,
  #shopify-section-{{ section.id }} .stc * {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
  #shopify-section-{{ section.id }} .stc::before { display: none !important; content: none !important; }

  .stc {
    display: block;
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
    margin-inline-end: calc(50% - 50vw);
    overflow: hidden;
  }
  .stc__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    min-height: {{ height_d }}px;
  }
  .stc--right .stc__image-wrap { order: 2; }
  .stc--right .stc__text-wrap { order: 1; }

  .stc__image-wrap {
    position: relative;
    overflow: hidden;
    background: #ece9e0;
    min-height: {{ height_d }}px;
  }
  .stc__image-wrap img,
  .stc__image-wrap picture {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    position: absolute;
    inset: 0;
  }

  .stc__text-wrap {
    background: {{ bg }};
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(40px, 4vw, 72px) clamp(28px, 5vw, 72px);
    min-height: {{ height_d }}px;
    color: {{ text_color }};
  }

  #shopify-section-{{ section.id }} .stc__eyebrow {
    font-family: {{ font_eyebrow }} !important;
    font-style: {% if eyebrow_font == 'serif-italic' %}italic{% else %}normal{% endif %} !important;
    font-size: {{ eyebrow_size }}px !important;
    font-weight: {% if eyebrow_font == 'sans-light' or eyebrow_font == 'mono-light' %}300{% elsif eyebrow_font == 'sans2' %}700{% else %}500{% endif %} !important;
    letter-spacing: {% if eyebrow_font == 'mono' or eyebrow_font == 'mono-light' %}0.04em{% elsif eyebrow_font == 'serif' or eyebrow_font == 'serif-italic' %}0.1em{% else %}0.16em{% endif %} !important;
    word-spacing: normal !important;
    text-transform: uppercase !important;
    color: {{ text_color }} !important;
    margin: 0 !important;
    line-height: 1 !important;
    align-self: flex-start;
  }
  #shopify-section-{{ section.id }} .stc__title,
  #shopify-section-{{ section.id }} h2.stc__title {
    font-family: {{ font_title }} !important;
    font-style: {% if title_font == 'serif-italic' %}italic{% else %}normal{% endif %} !important;
    font-size: {{ title_size }}px !important;
    font-weight: {% if title_font == 'sans-light' or title_font == 'mono-light' %}300{% elsif title_font == 'sans2' %}700{% else %}400{% endif %} !important;
    letter-spacing: {% if title_font == 'mono' or title_font == 'mono-light' %}-0.02em{% elsif title_font == 'serif' or title_font == 'serif-italic' %}-0.01em{% else %}-0.005em{% endif %} !important;
    word-spacing: {% if title_font == 'mono' or title_font == 'mono-light' %}-0.1em{% else %}-0.02em{% endif %} !important;
    line-height: 1.1 !important;
    color: {{ text_color }} !important;
    margin: 0 !important;
  }
  #shopify-section-{{ section.id }} .stc__description {
    font-family: {{ font_desc }} !important;
    font-style: {% if desc_font == 'serif-italic' %}italic{% else %}normal{% endif %} !important;
    font-size: {{ desc_size }}px !important;
    font-weight: {% if desc_font == 'sans-light' or desc_font == 'mono-light' %}300{% else %}400{% endif %} !important;
    letter-spacing: {% if desc_font == 'mono' or desc_font == 'mono-light' %}-0.01em{% else %}0{% endif %} !important;
    word-spacing: normal !important;
    line-height: 1.6 !important;
    color: {{ text_color }} !important;
    opacity: 0.86;
    margin: 16px 0 0 !important;
    max-width: 480px;
  }
  .stc__checks {
    list-style: none;
    padding: 0;
    margin: clamp(20px, 2vw, 28px) 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .stc__check {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: {{ font_check }} !important;
    font-style: {% if check_font == 'serif-italic' %}italic{% else %}normal{% endif %} !important;
    font-size: {{ check_size }}px !important;
    font-weight: {% if check_font == 'sans-light' or check_font == 'mono-light' %}300{% else %}400{% endif %} !important;
    letter-spacing: {% if check_font == 'mono' or check_font == 'mono-light' %}-0.01em{% else %}0{% endif %} !important;
    word-spacing: normal !important;
    color: {{ text_color }} !important;
    line-height: 1.5 !important;
  }
  .stc__check svg {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 4px;
    color: {{ check_color }};
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .stc__cta-wrap { align-self: flex-start; margin-top: clamp(20px, 2vw, 28px); }
  .stc__cta {
    font-family: {{ font_desc }};
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: {{ cta_color }};
    text-decoration: none;
    display: inline-block;
    padding-bottom: 3px;
    {% if cta_underline %}border-bottom: 1px solid {{ cta_color }};{% endif %}
    transition: opacity 200ms ease;
  }
  .stc__cta:hover { opacity: 0.7; }

  .stc__text-inner {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .stc__text-bottom {
    align-self: flex-start;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .stc__grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .stc--right .stc__image-wrap { order: 1; }
    .stc--right .stc__text-wrap { order: 2; }
    .stc__image-wrap {
      min-height: 0;
      height: {{ height_m }}px;
    }
    .stc__text-wrap {
      min-height: 0;
      padding: 36px 24px;
      gap: 24px;
    }
    .stc__title { font-size: {{ title_size | times: 0.65 | round }}px; }
    .stc__description { font-size: {{ desc_size | minus: 1 }}px; margin-top: 12px; }
    .stc__check { font-size: {{ check_size | minus: 1 }}px; }
  }
</style>

<section class="stc stc--{{ image_position }}" data-section-id="{{ section.id }}">
  <div class="stc__grid">
    <div class="stc__image-wrap">
      {%- if section.settings.image != blank -%}
        {%- assign d_w = section.settings.image.width | at_most: 1800 -%}
        {%- assign img_alt = section.settings.image.alt | default: title | escape -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 750w, {{ section.settings.image_mobile | image_url: width: 1100 }} 1100w" sizes="100vw">
          {%- endif -%}
          {{ section.settings.image | image_url: width: d_w | image_tag:
              loading: 'lazy',
              widths: '600,900,1200,1500,1800',
              sizes: '50vw',
              alt: img_alt
          }}
        </picture>
      {%- else -%}
        <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:{{ muted_color }};font-size:14px;">
          Sélectionnez une image
        </div>
      {%- endif -%}
    </div>

    <div class="stc__text-wrap">
      <div class="stc__text-top">
        {%- if eyebrow != blank -%}
          <p class="stc__eyebrow">{{ eyebrow | escape }}</p>
        {%- endif -%}
      </div>

      <div class="stc__text-inner">
        {%- if title != blank -%}
          <h2 class="stc__title">{{ title }}</h2>
        {%- endif -%}
        {%- if description != blank -%}
          <p class="stc__description">{{ description }}</p>
        {%- endif -%}
        {%- if checks.size > 0 -%}
          <ul class="stc__checks">
            {%- for c in checks -%}
              <li class="stc__check" {{ c.shopify_attributes }}>
                <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="4 12 10 18 20 6"/></svg>
                <span>{{ c.settings.text | escape }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="stc__text-bottom">
        {%- if cta_text != blank -%}
          <div class="stc__cta-wrap">
            {%- if cta_link != blank -%}
              <a href="{{ cta_link }}" class="stc__cta">{{ cta_text | escape }}</a>
            {%- else -%}
              <span class="stc__cta">{{ cta_text | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image + texte + checks",
  "tag": "section",
  "class": "split-text-checks-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile (optionnel)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position de l'image",
      "options": [
        { "value": "left", "label": "À gauche" },
        { "value": "right", "label": "À droite" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sur-titre (eyebrow)",
      "default": "CHAPITRE 0"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Le sac Ève"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (sous le titre)",
      "default": "Notre interprétation du sac quotidien : forme épurée, cuir noble, finitions main."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du CTA"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du CTA"
    },
    {
      "type": "checkbox",
      "id": "cta_underline",
      "label": "Soulignement du CTA",
      "default": true
    },
    {
      "type": "header",
      "content": "Polices (personnalisables)"
    },
    {
      "type": "select",
      "id": "eyebrow_font",
      "label": "Police du sur-titre",
      "options": [
        { "value": "sans", "label": "Founders Grotesk" },
        { "value": "sans-light", "label": "Founders Grotesk Light" },
        { "value": "mono", "label": "Founders Grotesk Mono" },
        { "value": "mono-light", "label": "Founders Grotesk Mono Light" },
        { "value": "serif", "label": "Serif (FontBaia1)" },
        { "value": "serif-italic", "label": "Serif Italique" }
      ],
      "default": "mono"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Police du titre",
      "options": [
        { "value": "sans", "label": "Founders Grotesk" },
        { "value": "sans-light", "label": "Founders Grotesk Light" },
        { "value": "mono", "label": "Founders Grotesk Mono" },
        { "value": "mono-light", "label": "Founders Grotesk Mono Light" },
        { "value": "serif", "label": "Serif (FontBaia1)" },
        { "value": "serif-italic", "label": "Serif Italique" }
      ],
      "default": "serif"
    },
    {
      "type": "select",
      "id": "desc_font",
      "label": "Police de la description",
      "options": [
        { "value": "sans", "label": "Founders Grotesk" },
        { "value": "sans-light", "label": "Founders Grotesk Light" },
        { "value": "mono", "label": "Founders Grotesk Mono" },
        { "value": "mono-light", "label": "Founders Grotesk Mono Light" },
        { "value": "serif", "label": "Serif (FontBaia1)" },
        { "value": "serif-italic", "label": "Serif Italique" }
      ],
      "default": "sans"
    },
    {
      "type": "select",
      "id": "check_font",
      "label": "Police des checks",
      "options": [
        { "value": "sans", "label": "Founders Grotesk" },
        { "value": "sans-light", "label": "Founders Grotesk Light" },
        { "value": "mono", "label": "Founders Grotesk Mono" },
        { "value": "mono-light", "label": "Founders Grotesk Mono Light" },
        { "value": "serif", "label": "Serif (FontBaia1)" },
        { "value": "serif-italic", "label": "Serif Italique" }
      ],
      "default": "sans"
    },
    {
      "type": "header",
      "content": "Tailles texte"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Taille sur-titre (px)",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 13,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille titre (px)",
      "min": 24,
      "max": 80,
      "step": 1,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Taille description (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "check_size",
      "label": "Taille checks (px)",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond (côté texte)",
      "default": "#f4efe5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Gris secondaire",
      "default": "#6a6a6a"
    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Couleur des checkmarks",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Couleur CTA"
    },
    {
      "type": "header",
      "content": "Taille"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur desktop",
      "min": 400,
      "max": 900,
      "step": 20,
      "default": 600,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Hauteur image mobile (px)",
      "info": "Réduisez si l'image prend trop de place sur smartphone.",
      "min": 180,
      "max": 700,
      "step": 10,
      "default": 280,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "check",
      "name": "Check (puce)",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Cuir pleine fleur"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image + texte + checks",
      "blocks": [
        { "type": "check", "settings": { "text": "Cuir pleine fleur, tannage végétal" } },
        { "type": "check", "settings": { "text": "Doublure intérieure en cuir suédé" } },
        { "type": "check", "settings": { "text": "Finitions à la main par nos artisans" } },
        { "type": "check", "settings": { "text": "Garantie 2 ans" } }
      ]
    }
  ]
}
{% endschema %}
