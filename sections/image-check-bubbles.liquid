{% liquid
  assign left_blocks = section.blocks | where: 'type', 'left'
  assign right_blocks = section.blocks | where: 'type', 'right'
%}
<style>
#shopify-section-{{ section.id }} .icb{width:100vw;margin-inline:calc(50% - 50vw);background:{{ section.settings.bg }};padding:{{ section.settings.pt_d }}px {{ section.settings.px_d }}px {{ section.settings.pb_d }}px;overflow:hidden}
#shopify-section-{{ section.id }} .icb__inner{max-width:{{ section.settings.max_w }}px;margin:0 auto}
#shopify-section-{{ section.id }} .icb__head{text-align:center;max-width:{{ section.settings.text_w }}px;margin:0 auto {{ section.settings.head_gap_d }}px}
#shopify-section-{{ section.id }} .icb__title{margin:0;color:{{ section.settings.title_color }};font-family:{% if section.settings.title_font == 'mono' %}'Founders Grotesk Mono',monospace{% elsif section.settings.title_font == 'serif' %}Georgia,serif{% else %}'Founders Grotesk',Arial,sans-serif{% endif %};font-size:{{ section.settings.title_size_d }}px;font-weight:{{ section.settings.title_weight }};line-height:1.05}
#shopify-section-{{ section.id }} .icb__desc{margin-top:{{ section.settings.desc_top }}px;color:{{ section.settings.desc_color }};font-family:{% if section.settings.desc_font == 'mono' %}'Founders Grotesk Mono',monospace{% elsif section.settings.desc_font == 'serif' %}Georgia,serif{% else %}'Founders Grotesk',Arial,sans-serif{% endif %};font-size:{{ section.settings.desc_size_d }}px;font-weight:{{ section.settings.desc_weight }};line-height:1.4}
#shopify-section-{{ section.id }} .icb__stage{display:grid;grid-template-columns:minmax(180px,1fr) minmax(240px,{{ section.settings.img_size_d }}px) minmax(180px,1fr);gap:{{ section.settings.col_gap_d }}px;align-items:center}
#shopify-section-{{ section.id }} .icb__img{width:min(100%,{{ section.settings.img_size_d }}px);margin:0 auto}
#shopify-section-{{ section.id }} .icb__img img{width:100%;height:auto;display:block}
#shopify-section-{{ section.id }} .icb__placeholder{aspect-ratio:1/1;background:rgba(255,255,255,.45);display:flex;align-items:center;justify-content:center}
#shopify-section-{{ section.id }} .icb__list{display:flex;flex-direction:column;gap:{{ section.settings.bubble_gap_d }}px}
#shopify-section-{{ section.id }} .icb__left{align-items:flex-end}#shopify-section-{{ section.id }} .icb__right{align-items:flex-start}
#shopify-section-{{ section.id }} .icb__item{display:flex;align-items:center;gap:{{ section.settings.dot_gap }}px}#shopify-section-{{ section.id }} .icb__right .icb__item{flex-direction:row-reverse}
#shopify-section-{{ section.id }} .icb__bubble{display:inline-flex;align-items:center;gap:{{ section.settings.check_gap_d }}px;min-height:{{ section.settings.bubble_h_d }}px;padding:{{ section.settings.bubble_py_d }}px {{ section.settings.bubble_px_d }}px;border-radius:{{ section.settings.radius }}px;background:{{ section.settings.bubble_bg }};border:{{ section.settings.border_w }}px solid {{ section.settings.border_color }};color:{{ section.settings.bubble_color }};font-family:{% if section.settings.bubble_font == 'mono' %}'Founders Grotesk Mono',monospace{% elsif section.settings.bubble_font == 'serif' %}Georgia,serif{% else %}'Founders Grotesk',Arial,sans-serif{% endif %};font-size:{{ section.settings.bubble_size_d }}px;font-weight:{{ section.settings.bubble_weight }};line-height:1;white-space:nowrap;box-shadow:0 4px 14px rgba(0,0,0,.08)}
#shopify-section-{{ section.id }} .icb__check{display:inline-flex;align-items:center;justify-content:center;width:{{ section.settings.check_box_d }}px;height:{{ section.settings.check_box_d }}px;flex:0 0 {{ section.settings.check_box_d }}px;border-radius:999px;border:{{ section.settings.check_border }}px solid {{ section.settings.check_color }};color:{{ section.settings.check_color }};background:{{ section.settings.check_bg }};font-family:{% if section.settings.check_font == 'mono' %}'Founders Grotesk Mono',monospace{% elsif section.settings.check_font == 'serif' %}Georgia,serif{% else %}'Founders Grotesk',Arial,sans-serif{% endif %};font-size:{{ section.settings.check_size_d }}px;font-weight:{{ section.settings.check_weight }}}
#shopify-section-{{ section.id }} .icb__dot{display:{% if section.settings.show_dots %}block{% else %}none{% endif %};width:{{ section.settings.dot_size }}px;height:{{ section.settings.dot_size }}px;border-radius:50%;background:{{ section.settings.dot_color }};box-shadow:0 0 0 5px color-mix(in srgb,{{ section.settings.dot_color }} 18%,transparent)}
#shopify-section-{{ section.id }} .icb__mobile{display:none}
@media(max-width:749px){#shopify-section-{{ section.id }} .icb{padding:{{ section.settings.pt_m }}px {{ section.settings.px_m }}px {{ section.settings.pb_m }}px}#shopify-section-{{ section.id }} .icb__head{margin-bottom:{{ section.settings.head_gap_m }}px}#shopify-section-{{ section.id }} .icb__title{font-size:{{ section.settings.title_size_m }}px}#shopify-section-{{ section.id }} .icb__desc{font-size:{{ section.settings.desc_size_m }}px}#shopify-section-{{ section.id }} .icb__stage{display:block}#shopify-section-{{ section.id }} .icb__stage>.icb__list{display:none}#shopify-section-{{ section.id }} .icb__img{width:min(100%,{{ section.settings.img_size_m }}px);margin-bottom:{{ section.settings.img_gap_m }}px}#shopify-section-{{ section.id }} .icb__mobile{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:{{ section.settings.bubble_gap_m }}px {{ section.settings.mobile_col_gap }}px}#shopify-section-{{ section.id }} .icb__mobile-col{display:flex;flex-direction:column;gap:{{ section.settings.bubble_gap_m }}px;min-width:0}#shopify-section-{{ section.id }} .icb__mobile .icb__dot{display:none}#shopify-section-{{ section.id }} .icb__bubble{width:100%;white-space:normal;min-height:{{ section.settings.bubble_h_m }}px;padding:{{ section.settings.bubble_py_m }}px {{ section.settings.bubble_px_m }}px;font-size:{{ section.settings.bubble_size_m }}px;gap:{{ section.settings.check_gap_m }}px}#shopify-section-{{ section.id }} .icb__check{width:{{ section.settings.check_box_m }}px;height:{{ section.settings.check_box_m }}px;flex-basis:{{ section.settings.check_box_m }}px;font-size:{{ section.settings.check_size_m }}px}}
</style>
<section class="icb"><div class="icb__inner"><div class="icb__head">{% if section.settings.title != blank %}<h2 class="icb__title">{{ section.settings.title }}</h2>{% endif %}{% if section.settings.description != blank %}<div class="icb__desc">{{ section.settings.description }}</div>{% endif %}</div><div class="icb__stage"><div class="icb__list icb__left">{% for block in left_blocks limit: 3 %}<div class="icb__item" {{ block.shopify_attributes }}><span class="icb__bubble"><span class="icb__check">{{ section.settings.check_symbol }}</span>{{ block.settings.text }}</span><span class="icb__dot"></span></div>{% endfor %}</div><div class="icb__img">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '360,540,720,900,1100,1400', sizes: '(max-width: 749px) 90vw, 50vw', alt: section.settings.title }}{% else %}<div class="icb__placeholder">Image</div>{% endif %}</div><div class="icb__list icb__right">{% for block in right_blocks limit: 3 %}<div class="icb__item" {{ block.shopify_attributes }}><span class="icb__bubble"><span class="icb__check">{{ section.settings.check_symbol }}</span>{{ block.settings.text }}</span><span class="icb__dot"></span></div>{% endfor %}</div></div><div class="icb__mobile"><div class="icb__mobile-col">{% for block in left_blocks limit: 3 %}<div class="icb__item" {{ block.shopify_attributes }}><span class="icb__bubble"><span class="icb__check">{{ section.settings.check_symbol }}</span>{{ block.settings.text }}</span></div>{% endfor %}</div><div class="icb__mobile-col">{% for block in right_blocks limit: 3 %}<div class="icb__item" {{ block.shopify_attributes }}><span class="icb__bubble"><span class="icb__check">{{ section.settings.check_symbol }}</span>{{ block.settings.text }}</span></div>{% endfor %}</div></div></div></section>
{% schema %}
{"name":"Image + checks","tag":"section","class":"image-check-bubbles-section","max_blocks":6,"settings":[{"type":"header","content":"Texte"},{"type":"text","id":"title","label":"Titre","default":"The Perfect Everyday Bag"},{"type":"richtext","id":"description","label":"Description","default":"<p>Une description courte sous le titre.</p>"},{"type":"select","id":"title_font","label":"Police titre","options":[{"value":"sans","label":"Founders Grotesk"},{"value":"mono","label":"Founders Grotesk Mono"},{"value":"serif","label":"Serif"}],"default":"sans"},{"type":"range","id":"title_size_d","label":"Taille titre desktop","min":18,"max":110,"step":1,"default":54,"unit":"px"},{"type":"range","id":"title_size_m","label":"Taille titre mobile","min":16,"max":70,"step":1,"default":34,"unit":"px"},{"type":"range","id":"title_weight","label":"Graisse titre","min":100,"max":900,"step":100,"default":500},{"type":"select","id":"desc_font","label":"Police description","options":[{"value":"sans","label":"Founders Grotesk"},{"value":"mono","label":"Founders Grotesk Mono"},{"value":"serif","label":"Serif"}],"default":"sans"},{"type":"range","id":"desc_size_d","label":"Taille description desktop","min":10,"max":40,"step":1,"default":18,"unit":"px"},{"type":"range","id":"desc_size_m","label":"Taille description mobile","min":10,"max":32,"step":1,"default":15,"unit":"px"},{"type":"range","id":"desc_weight","label":"Graisse description","min":100,"max":900,"step":100,"default":400},{"type":"range","id":"desc_top","label":"Espace titre / description","min":0,"max":60,"step":2,"default":12,"unit":"px"},{"type":"header","content":"Image"},{"type":"image_picker","id":"image","label":"Image centrale"},{"type":"range","id":"img_size_d","label":"Taille image desktop","min":220,"max":900,"step":10,"default":520,"unit":"px"},{"type":"range","id":"img_size_m","label":"Taille image mobile","min":160,"max":520,"step":10,"default":330,"unit":"px"},{"type":"header","content":"Bulles"},{"type":"select","