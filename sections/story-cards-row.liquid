{%- liquid
  assign bg = section.settings.bg_color | default: '#ececec'
  assign card_bg = section.settings.card_bg | default: '#ffffff'
  assign text_color = section.settings.text_color | default: '#0f0f0f'
  assign muted_color = section.settings.muted_color | default: '#6f6f6f'
  assign accent_color = section.settings.accent_color | default: '#0f0f0f'
  assign title_font = section.settings.title_font | default: 'sans2'
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign title_position = section.settings.title_position | default: 'left'
  assign image_ratio = section.settings.image_ratio | default: '4-5'
  assign show_arrows = section.settings.show_arrows
  assign show_progress = section.settings.show_progress
  assign cards = section.blocks | where: 'type', 'card'
-%}

<style>
  #shopify-section-{{ section.id }} {
    background: {{ bg }};
    color: {{ text_color }};
  }
  #shopify-section-{{ section.id }} .scr,
  #shopify-section-{{ section.id }} .scr * {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
  #shopify-section-{{ section.id }} .scr::before { display: none !important; content: none !important; }

  .scr {
    display: block;
    width: 100%;
    padding: clamp(40px, 5vw, 80px) 0;
  }
  .scr__inner {
    display: grid;
    grid-template-columns: minmax(260px, 360px) 1fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: flex-start;
    padding-left: clamp(20px, 5vw, 60px);
    padding-right: 0;
    max-width: 1700px;
    margin: 0 auto;
  }
  .scr--right .scr__inner {
    grid-template-columns: 1fr minmax(260px, 360px);
    padding-right: clamp(20px, 5vw, 60px);
    padding-left: 0;
  }
  .scr--right .scr__heading { order: 2; }
  .scr--right .scr__carousel-wrap { order: 1; }

  .scr__heading {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-block: clamp(20px, 3vw, 60px);
  }
  .scr__title {
    font-family: {% if title_font == 'serif' %}'Cormorant Garamond', 'Playfair Display', 'Times New Roman', Georgia, serif{% elsif title_font == 'sans' %}'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif{% else %}'Founders Grotesk', 'Helvetica Neue', Arial, sans-serif{% endif %};
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: {{ text_color }};
    margin: 0;
  }
  .scr__subtitle {
    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
    font-size: 14.5px;
    font-weight: 400;
    letter-spacing: 0.005em;
    line-height: 1.55;
    color: {{ muted_color }};
    margin: 0;
    max-width: 340px;
  }

  /* Carousel */
  .scr__carousel-wrap {
    position: relative;
    min-width: 0;
  }
  .scr__carousel {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 16px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 4px 0 20px;
    margin: 0;
  }
  .scr__carousel::-webkit-scrollbar { display: none; }
  .scr__card {
    flex: 0 0 clamp(220px, 22vw, 320px);
    scroll-snap-align: start;
    background: {{ card_bg }};
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 250ms ease;
    border-radius: 4px;
  }
  .scr__card:hover { transform: translateY(-3px); }
  .scr__card-image {
    position: relative;
    width: 100%;
    {% case image_ratio %}
      {% when '1-1' %}aspect-ratio: 1 / 1;
      {% when '4-5' %}aspect-ratio: 4 / 5;
      {% when '3-4' %}aspect-ratio: 3 / 4;
      {% when '5-6' %}aspect-ratio: 5 / 6;
      {% when '2-3' %}aspect-ratio: 2 / 3;
    {% endcase %}
    overflow: hidden;
    background: {{ card_bg }};
  }
  .scr__card-image img,
  .scr__card-image picture {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    position: absolute;
    inset: 0;
    transition: transform 700ms ease;
  }
  .scr__card:hover .scr__card-image img { transform: scale(1.04); }
  .scr__card-body {
    padding: 14px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .scr__card-eyebrow {
    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: {{ muted_color }};
    margin: 0;
    line-height: 1.35;
  }
  .scr__card-title {
    font-family: 'Founders Grotesk', 'Founders Grotesk', 'Helvetica Neue', 'Inter', Arial, sans-serif;
    font-size: 14.5px;
    font-weight: 700;
    letter-spacing: 0.005em;
    color: {{ text_color }};
    margin: 0;
    line-height: 1.3;
  }

  /* Arrows */
  .scr__arrow {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 0;
    background: {{ accent_color }};
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 4;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    padding: 0;
    transition: opacity 200ms ease;
  }
  .scr__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .scr__arrow svg { width: 16px; height: 16px; }
  .scr__arrow--prev { left: -18px; }
  .scr__arrow--next { right: 0; }
  .scr--right .scr__arrow--prev { left: 0; }
  .scr--right .scr__arrow--next { right: -18px; }

  /* Progress bar */
  .scr__progress {
    margin-top: 8px;
    height: 1px;
    width: 100%;
    background: rgba(0,0,0,0.12);
    position: relative;
    overflow: hidden;
  }
  .scr__progress-bar {
    position: absolute;
    inset: 0 auto 0 0;
    width: 30%;
    background: {{ accent_color }};
    transition: width 200ms ease, left 200ms ease;
  }

  /* Mobile */
  @media screen and (max-width: 849px) {
    .scr { padding: 40px 0; }
    .scr__inner {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 28px;
    }
    .scr--right .scr__inner {
      padding: 0 20px;
    }
    .scr--right .scr__heading { order: 1; }
    .scr--right .scr__carousel-wrap { order: 2; }
    .scr__heading { padding-block: 0; }
    .scr__title { font-size: clamp(24px, 6.5vw, 32px); }
    .scr__subtitle { font-size: 14px; max-width: 100%; }
    .scr__carousel-wrap {
      margin-inline: -20px;
    }
    .scr__carousel { padding: 4px 20px 16px; }
    .scr__card { flex: 0 0 78%; }
    .scr__arrow { display: none; }
  }
</style>

<section class="scr scr--{{ title_position }}" data-section-id="{{ section.id }}" data-story-cards-row>
  <div class="scr__inner">
    <div class="scr__heading">
      {%- if title != blank -%}
        <h2 class="scr__title">{{ title }}</h2>
      {%- endif -%}
      {%- if subtitle != blank -%}
        <p class="scr__subtitle">{{ subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="scr__carousel-wrap">
      {%- if show_arrows -%}
        <button type="button" class="scr__arrow scr__arrow--prev" aria-label="Précédent" data-scr-prev>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button type="button" class="scr__arrow scr__arrow--next" aria-label="Suivant" data-scr-next>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {%- endif -%}

      <div class="scr__carousel" data-scr-track>
        {%- for block in cards -%}
          {%- assign label = block.settings.label -%}
          {%- assign eyebrow = block.settings.eyebrow -%}
          {%- assign link = block.settings.link -%}
          {%- assign img = block.settings.image -%}
          {%- assign tag = 'div' -%}
          {%- if link != blank -%}{% assign tag = 'a' %}{%- endif -%}
          <{{ tag }} class="scr__card"
            {% if link != blank %} href="{{ link }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="scr__card-image">
              {%- if img != blank -%}
                {%- assign max_w = img.width | at_most: 1200 -%}
                {%- assign img_alt = img.alt | default: label | escape -%}
                {{ img | image_url: width: max_w | image_tag:
                  loading: 'lazy',
                  widths: '320,440,560,720,900,1200',
                  sizes: '(max-width: 849px) 78vw, 320px',
                  alt: img_alt
                }}
              {%- endif -%}
            </div>
            <div class="scr__card-body">
              {%- if eyebrow != blank -%}
                <p class="scr__card-eyebrow">{{ eyebrow | escape }}</p>
              {%- endif -%}
              {%- if label != blank -%}
                <p class="scr__card-title">{{ label | escape }}</p>
              {%- endif -%}
            </div>
          </{{ tag }}>
        {%- endfor -%}
      </div>

      {%- if show_progress -%}
        <div class="scr__progress" aria-hidden="true">
          <div class="scr__progress-bar" data-scr-progress></div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('#shopify-section-{{ section.id }} [data-story-cards-row]');
    if (!root) return;
    var track = root.querySelector('[data-scr-track]');
    if (!track) return;
    var prev = root.querySelector('[data-scr-prev]');
    var next = root.querySelector('[data-scr-next]');
    var progressBar = root.querySelector('[data-scr-progress]');

    function step() {
      var card = track.querySelector('.scr__card');
      if (!card) return track.clientWidth * 0.5;
      var style = getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap || '0') || 0;
      return card.getBoundingClientRect().width + gap;
    }
    function update() {
      var max = Math.max(1, track.scrollWidth - track.clientWidth);
      var pct = Math.min(1, track.scrollLeft / max);
      if (progressBar) {
        var visibleRatio = track.clientWidth / track.scrollWidth;
        progressBar.style.width = (visibleRatio * 100).toFixed(2) + '%';
        progressBar.style.left = (pct * (1 - visibleRatio) * 100).toFixed(2) + '%';
      }
      if (prev) prev.disabled = track.scrollLeft <= 4;
      if (next) next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 4;
    }
    if (prev) prev.addEventListener('click', function () {
      track.scrollBy({ left: -step(), behavior: 'smooth' });
    });
    if (next) next.addEventListener('click', function () {
      track.scrollBy({ left: step(), behavior: 'smooth' });
    });
    track.addEventListener('scroll', function () {
      if (track._scrRaf) cancelAnimationFrame(track._scrRaf);
      track._scrRaf = requestAnimationFrame(update);
    }, { passive: true });
    window.addEventListener('resize', update);
    setTimeout(update, 80);
  })();
</script>

{% schema %}
{
  "name": "Cartes histoires",
  "tag": "section",
  "class": "story-cards-row-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Titre"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Les histoires derrière nos produits"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Design démocratique, directement du cœur de notre atelier."
    },
    {
      "type": "select",
      "id": "title_position",
      "label": "Position du titre",
      "options": [
        { "value": "left", "label": "À gauche (cartes à droite)" },
        { "value": "right", "label": "À droite (cartes à gauche)" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Police du titre",
      "options": [
        { "value": "sans2", "label": "Sans (FontBaia2 — bold)" },
        { "value": "sans", "label": "Sans système" },
        { "value": "serif", "label": "Serif (FontBaia1)" }
      ],
      "default": "sans2"
    },
    {
      "type": "header",
      "content": "Cartes"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format des images",
      "options": [
        { "value": "1-1", "label": "Carré 1:1" },
        { "value": "4-5", "label": "Portrait 4:5 (recommandé)" },
        { "value": "3-4", "label": "Portrait 3:4" },
        { "value": "5-6", "label": "Presque carré 5:6" },
        { "value": "2-3", "label": "Portrait 2:3" }
      ],
      "default": "4-5"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Afficher les flèches de navigation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Afficher la barre de progression",
      "default": true
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond de la section",
      "default": "#ececec"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Titre et libellés",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Sous-titre, éléments secondaires (gris)",
      "default": "#6f6f6f"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Flèches et barre de progression",
      "default": "#0f0f0f"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Carte histoire",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Petite légende du haut",
          "default": "Designed by Akanksha Deo",
          "info": "Ex: \"Designed by [Nom]\" ou \"Made in Italy\""
        },
        {
          "type": "text",
          "id": "label",
          "label": "Titre de la carte",
          "default": "BRÖNDEN rug"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cartes histoires",
      "blocks": [
        { "type": "card", "settings": { "eyebrow": "Designed by Akanksha Deo", "label": "BRÖNDEN rug" } },
        { "type": "card", "settings": { "eyebrow": "Designed by Iina Vuorivirta", "label": "SYMFONISK lamp" } },
        { "type": "card", "settings": { "eyebrow": "Designed by Mikael Axelsson", "label": "BURVIK table" } },
        { "type": "card", "settings": { "eyebrow": "Designed by Studio", "label": "EKET cabinet" } }
      ]
    }
  ]
}
{% endschema %}
