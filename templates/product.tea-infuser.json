        "liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Customer Reviews</title>\n  <style>\n    * {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n      background: #f8f8f8;\n      padding: 20px;\n    }\n\n    .reviews-wrapper {\n      width: 100%;\n      max-width: 1200px;\n      margin: 0 auto;\n      padding: 20px;\n      background: white;\n      border-radius: 16px;\n    }\n\n    .reviews-title {\n      text-align: center;\n      margin-bottom: 12px;\n    }\n\n    .reviews-title h2 {\n      font-size: 28px;\n      font-weight: 700;\n      background: linear-gradient(135deg, #f13322 0%, #ff6b5e 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n      margin-bottom: 8px;\n      line-height: 1.2;\n    }\n\n    .reviews-subtitle {\n      font-size: 14px;\n      color: #666;\n      font-weight: 400;\n      margin-bottom: 20px;\n    }\n\n    .reviews-categories {\n      display: flex;\n      justify-content: center;\n      gap: 10px;\n      margin-bottom: 30px;\n      flex-wrap: wrap;\n    }\n\n    .category-tab {\n      background: rgba(241, 51, 34, 0.06);\n      border: 1.5px solid rgba(241, 51, 34, 0.12);\n      color: #f13322;\n      padding: 8px 20px;\n      border-radius: 50px;\n      font-size: 13px;\n      font-weight: 600;\n      cursor: pointer;\n      transition: all 0.3s ease;\n    }\n\n    .category-tab:hover {\n      background: rgba(241, 51, 34, 0.1);\n      transform: translateY(-1px);\n    }\n\n    .category-tab.active {\n      background: linear-gradient(135deg, #f13322 0%, #ff6b5e 100%);\n      color: white;\n      border-color: #f13322;\n      box-shadow: 0 3px 10px rgba(241, 51, 34, 0.25);\n    }\n\n    .reviews-container {\n      position: relative;\n      overflow: hidden;\n      padding: 10px 0;\n    }\n\n    .reviews-track {\n      display: flex;\n      gap: 20px;\n      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    .review-card {\n      flex: 0 0 calc((100% - 40px) / 3);\n      background: #FFFFFF;\n      border-radius: 16px;\n      padding: 20px;\n      box-shadow: 0 4px 16px rgba(241, 51, 34, 0.08);\n      position: relative;\n      transition: all 0.3s ease;\n      border: 1px solid rgba(241, 51, 34, 0.08);\n      display: flex;\n      flex-direction: column;\n      min-height: 280px;\n    }\n\n    .review-card::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      height: 3px;\n      background: linear-gradient(90deg, #f13322 0%, #ff6b5e 50%, #ffb6c1 100%);\n      border-radius: 16px 16px 0 0;\n    }\n\n    .review-card:hover {\n      transform: translateY(-5px);\n      box-shadow: 0 8px 24px rgba(241, 51, 34, 0.15);\n    }\n\n    .review-header {\n      display: flex;\n      align-items: center;\n      margin-bottom: 12px;\n    }\n\n    .reviewer-info {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      flex: 1;\n    }\n\n    .reviewer-avatar {\n      width: 44px;\n      height: 44px;\n      border-radius: 50%;\n      background: linear-gradient(135deg, #f13322 0%, #ff6b5e 100%);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      color: white;\n      font-size: 18px;\n      font-weight: 700;\n      flex-shrink: 0;\n      box-shadow: 0 2px 8px rgba(241, 51, 34, 0.3);\n    }\n\n    .reviewer-details {\n      flex: 1;\n    }\n\n    .reviewer-name {\n      font-size: 16px;\n      font-weight: 700;\n      color: #2d2d2d;\n      margin-bottom: 4px;\n      line-height: 1.2;\n    }\n\n    .review-date {\n      color: #999;\n      font-size: 12px;\n      font-weight: 500;\n    }\n\n    .review-stars {\n      display: flex;\n      gap: 3px;\n      margin-bottom: 12px;\n    }\n\n    .star {\n      color: #f13322;\n      font-size: 16px;\n      filter: drop-shadow(0 1px 2px rgba(241, 51, 34, 0.25));\n    }\n\n    .review-text {\n      font-size: 14px;\n      line-height: 1.6;\n      color: #444;\n      margin-bottom: 12px;\n      flex-grow: 1;\n    }\n\n    .review-images {\n      display: flex;\n      gap: 8px;\n      margin-bottom: 12px;\n      flex-wrap: wrap;\n    }\n\n    .review-image {\n      width: 70px;\n      height: 70px;\n      border-radius: 8px;\n      overflow: hidden;\n      cursor: pointer;\n      transition: all 0.2s ease;\n      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\n      border: 2px solid transparent;\n    }\n\n    .review-image:hover {\n      transform: scale(1.05);\n      border-color: #ffb6c1;\n    }\n\n    .review-image img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    .verified-badge {\n      display: inline-flex;\n      align-items: center;\n      gap: 5px;\n      background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);\n      color: #2E7D32;\n      font-size: 11px;\n      font-weight: 600;\n      padding: 6px 12px;\n      border-radius: 12px;\n      margin-top: auto;\n      align-self: flex-start;\n    }\n\n    .verified-badge svg {\n      width: 10px;\n      height: 10px;\n    }\n\n    .carousel-controls {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 16px;\n      margin-top: 30px;\n    }\n\n    .carousel-arrow {\n      width: 40px;\n      height: 40px;\n      border-radius: 50%;\n      background: transparent;\n      border: 2px solid #f13322;\n      color: #f13322;\n      cursor: pointer;\n      transition: all 0.25s ease;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .carousel-arrow:hover:not(:disabled) {\n      background: linear-gradient(135deg, #f13322, #ff6b5e);\n      color: white;\n      transform: scale(1.05);\n      box-shadow: 0 4px 12px rgba(241, 51, 34, 0.3);\n    }\n\n    .carousel-arrow:disabled {\n      opacity: 0.3;\n      cursor: not-allowed;\n    }\n\n    .carousel-indicators {\n      display: flex;\n      gap: 8px;\n    }\n\n    .indicator {\n      width: 10px;\n      height: 10px;\n      border-radius: 50%;\n      background: #ffb6c1;\n      cursor: pointer;\n      transition: all 0.3s ease;\n      border: none;\n      padding: 0;\n      opacity: 0.5;\n    }\n\n    .indicator:hover {\n      opacity: 0.8;\n      transform: scale(1.1);\n    }\n\n    .indicator.active {\n      background: #f13322;\n      opacity: 1;\n      transform: scale(1.2);\n    }\n\n    .image-lightbox {\n      display: none;\n      position: fixed;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      background: rgba(0, 0, 0, 0.9);\n      z-index: 9999;\n      justify-content: center;\n      align-items: center;\n      cursor: pointer;\n    }\n\n    .image-lightbox.active {\n      display: flex;\n    }\n\n    .lightbox-content {\n      max-width: 90%;\n      max-height: 90%;\n      object-fit: contain;\n      border-radius: 8px;\n      box-shadow: 0 10px 50px rgba(241, 51, 34, 0.5);\n    }\n\n    .lightbox-close {\n      position: absolute;\n      top: 20px;\n      right: 30px;\n      color: white;\n      font-size: 40px;\n      font-weight: 300;\n      cursor: pointer;\n      transition: all 0.2s ease;\n    }\n\n    .lightbox-close:hover {\n      color: #ffb6c1;\n      transform: scale(1.1);\n    }\n\n    @media (max-width: 1024px) {\n      .review-card {\n        flex: 0 0 calc((100% - 20px) / 2);\n      }\n    }\n\n    @media (max-width: 768px) {\n      .reviews-wrapper {\n        padding: 15px;\n      }\n\n      .reviews-title h2 {\n        font-size: 22px;\n      }\n\n      .reviews-subtitle {\n        font-size: 12px;\n      }\n\n      .reviews-categories {\n        gap: 8px;\n        margin-bottom: 20px;\n      }\n\n      .category-tab {\n        padding: 6px 16px;\n        font-size: 11px;\n      }\n\n      .review-card {\n        flex: 0 0 100%;\n        min-height: auto;\n      }\n\n      .reviewer-avatar {\n        width: 36px;\n        height: 36px;\n        font-size: 16px;\n      }\n\n      .reviewer-name {\n        font-size: 14px;\n      }\n\n      .review-text {\n        font-size: 13px;\n      }\n\n      .review-image {\n        width: 60px;\n        height: 60px;\n      }\n\n      .carousel-arrow {\n        width: 36px;\n        height: 36px;\n      }\n\n      .carousel-controls {\n        margin-top: 20px;\n      }\n    }\n  </style>\n</head>\n<body>\n\n<div class=\"reviews-wrapper\">\n  <div class=\"reviews-title\">\n    <h2>What Our Customers Say</h2>\n    <p class=\"reviews-subtitle\">Hundreds of women trust us</p>\n  </div>\n\n  <div class=\"reviews-categories\">\n    <button class=\"category-tab active\" data-category=\"all\">All Reviews</button>\n    <button class=\"category-tab\" data-category=\"weight\">Weight</button>\n    <button class=\"category-tab\" data-category=\"hair\">Hair</button>\n    <button class=\"category-tab\" data-category=\"skin\">Skin</button>\n    <button class=\"category-tab\" data-category=\"periods\">Periods</button>\n    <button class=\"category-tab\" data-category=\"fertility\">Fertility</button>\n    <button class=\"category-tab\" data-category=\"mood\">Mood</button>\n    <button class=\"category-tab\" data-category=\"facialhair\">Facial Hair</button>\n  </div>\n\n  <div class=\"reviews-container\">\n    <div class=\"reviews-track\" id=\"reviewsTrack\">\n      \n      <div class=\"review-card\" data-category=\"weight\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">C</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Caroline</div>\n              <div class=\"review-date\">August 9, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          Very high quality product, targeted exactly for people with PCOS and easy to take too. I highly recommend it!\n        </div>\n        <div class=\"review-images\">\n          <div class=\"review-image\" onclick=\"openLightbox('https://cdn.shopify.com/s/files/1/0868/4496/5201/files/12.png?v=1766066809')\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0868/4496/5201/files/12.png?v=1766066809\" alt=\"Product photo\">\n          </div>\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n      <div class=\"review-card\" data-category=\"periods\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">E</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Emma</div>\n              <div class=\"review-date\">July 15, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          A natural solution that changed my life! I've been taking this supplement for 3 months and the results are there. My cycle is more regular.\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n      <div class=\"review-card\" data-category=\"mood\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">S</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Sophie</div>\n              <div class=\"review-date\">June 22, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          Excellent product! I noticed a significant improvement in my overall well-being. The capsules are easy to swallow and well tolerated.\n        </div>\n        <div class=\"review-images\">\n          <div class=\"review-image\" onclick=\"openLightbox('https://cdn.shopify.com/s/files/1/0868/4496/5201/files/12.png?v=1766066809')\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0868/4496/5201/files/12.png?v=1766066809\" alt=\"Product photo\">\n          </div>\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n      <div class=\"review-card\" data-category=\"hair\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">M</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Marie</div>\n              <div class=\"review-date\">May 10, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          Recommended by my gynecologist. After 2 months of use, I see real benefits. The product quality is impeccable.\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n      <div class=\"review-card\" data-category=\"skin\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">L</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Laura</div>\n              <div class=\"review-date\">April 3, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          Very satisfied with this product. I highly recommend it to all women looking for a natural and effective solution for their well-being.\n        </div>\n        <div class=\"review-images\">\n          <div class=\"review-image\" onclick=\"openLightbox('https://cdn.shopify.com/s/files/1/0868/4496/5201/files/12.png?v=1766066809')\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0868/4496/5201/files/12.png?v=1766066809\" alt=\"Product photo\">\n          </div>\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n      <div class=\"review-card\" data-category=\"fertility\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">A</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Alice</div>\n              <div class=\"review-date\">March 28, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          Quality product with transparent composition. I feel better since I take it daily. Very good value for money.\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n      <div class=\"review-card\" data-category=\"facialhair\">\n        <div class=\"review-header\">\n          <div class=\"reviewer-info\">\n            <div class=\"reviewer-avatar\">J</div>\n            <div class=\"reviewer-details\">\n              <div class=\"reviewer-name\">Jessica</div>\n              <div class=\"review-date\">March 15, 2025</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"review-stars\">\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n          <span class=\"star\">★</span>\n        </div>\n        <div class=\"review-text\">\n          Amazing results! My unwanted facial hair growth has significantly reduced. I finally feel confident again.\n        </div>\n        <div class=\"verified-badge\">\n          <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/>\n          </svg>\n          Verified Purchase\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"carousel-controls\">\n    <button class=\"carousel-arrow prev\" id=\"prevBtn\" aria-label=\"Previous\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <path d=\"M15 18l-6-6 6-6\"/>\n      </svg>\n    </button>\n    \n    <div class=\"carousel-indicators\" id=\"indicators\"></div>\n    \n    <button class=\"carousel-arrow next\" id=\"nextBtn\" aria-label=\"Next\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <path d=\"M9 18l6-6-6-6\"/>\n      </svg>\n    </button>\n  </div>\n</div>\n\n<div class=\"image-lightbox\" id=\"imageLightbox\" onclick=\"closeLightbox()\">\n  <span class=\"lightbox-close\">&times;</span>\n  <img class=\"lightbox-content\" id=\"lightboxImage\">\n</div>\n\n<script>\n  (function() {\n    const track = document.getElementById('reviewsTrack');\n    const prevBtn = document.getElementById('prevBtn');\n    const nextBtn = document.getElementById('nextBtn');\n    const indicatorsContainer = document.getElementById('indicators');\n    const categoryTabs = document.querySelectorAll('.category-tab');\n    const allCards = Array.from(track.querySelectorAll('.review-card'));\n    \n    let currentIndex = 0;\n    let currentCategory = 'all';\n    let visibleCards = allCards;\n    \n    function getCardsPerView() {\n      if (window.innerWidth <= 768) return 1;\n      if (window.innerWidth <= 1024) return 2;\n      return 3;\n    }\n    \n    function filterCards() {\n      if (currentCategory === 'all') {\n        visibleCards = allCards;\n      } else {\n        visibleCards = allCards.filter(card => card.dataset.category === currentCategory);\n      }\n      \n      allCards.forEach(card => card.style.display = 'none');\n      visibleCards.forEach(card => card.style.display = 'flex');\n      \n      currentIndex = 0;\n      createIndicators();\n      updateCarousel();\n    }\n    \n    function createIndicators() {\n      const cardsPerView = getCardsPerView();\n      const numIndicators = Math.ceil(visibleCards.length / cardsPerView);\n      indicatorsContainer.innerHTML = '';\n      \n      for (let i = 0; i < numIndicators; i++) {\n        const indicator = document.createElement('button');\n        indicator.className = 'indicator';\n        indicator.setAttribute('aria-label', `Go to page ${i + 1}`);\n        if (i === 0) indicator.classList.add('active');\n        \n        indicator.addEventListener('click', () => {\n          currentIndex = i;\n          updateCarousel();\n        });\n        \n        indicatorsContainer.appendChild(indicator);\n      }\n    }\n    \n    function updateIndicators() {\n      const indicators = indicatorsContainer.querySelectorAll('.indicator');\n      indicators.forEach((indicator, index) => {\n        indicator.classList.toggle('active', index === currentIndex);\n      });\n    }\n    \n    function updateCarousel() {\n      const cardsPerView = getCardsPerView();\n      const maxIndex = Math.max(0, Math.ceil(visibleCards.length / cardsPerView) - 1);\n      \n      currentIndex = Math.min(currentIndex, maxIndex);\n      \n      if (visibleCards.length > 0) {\n        const cardElement = visibleCards[0];\n        const cardWidth = cardElement.offsetWidth;\n        const gap = 20;\n        const offset = -(currentIndex * cardsPerView * (cardWidth + gap));\n        \n        track.style.transform = `translateX(${offset}px)`;\n      }\n      \n      prevBtn.disabled = currentIndex === 0;\n      nextBtn.disabled = currentIndex >= maxIndex;\n      \n      updateIndicators();\n    }\n\n    categoryTabs.forEach(tab => {\n      tab.addEventListener('click', () => {\n        categoryTabs.forEach(t => t.classList.remove('active'));\n        tab.classList.add('active');\n        currentCategory = tab.dataset.category;\n        filterCards();\n      });\n    });\n\n    prevBtn.addEventListener('click', () => {\n      if (currentIndex > 0) {\n        currentIndex--;\n        updateCarousel();\n      }\n    });\n\n    nextBtn.addEventListener('click', () => {\n      const cardsPerView = getCardsPerView();\n      const maxIndex = Math.max(0, Math.ceil(visibleCards.length / cardsPerView) - 1);\n      if (currentIndex < maxIndex) {\n        currentIndex++;\n        updateCarousel();\n      }\n    });\n\n    let resizeTimeout;\n    window.addEventListener('resize', () => {\n      clearTimeout(resizeTimeout);\n      resizeTimeout = setTimeout(() => {\n        createIndicators();\n        updateCarousel();\n      }, 100);\n    });\n\n    filterCards();\n  })();\n\n  function openLightbox(imageUrl) {\n    const lightbox = document.getElementById('imageLightbox');\n    const lightboxImage = document.getElementById('lightboxImage');\n    lightboxImage.src = imageUrl;\n    lightbox.classList.add('active');\n    document.body.style.overflow = 'hidden';\n  }\n\n  function closeLightbox() {\n    const lightbox = document.getElementById('imageLightbox');\n    lightbox.classList.remove('active');\n    document.body.style.overflow = '';\n  }\n\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') {\n      closeLightbox();\n    }\n  });\n</script>\n\n</body>\n</html>",
